%% Umbrella project layout (ADR 0007)
{project_app_dirs, ["apps/*"]}.

{erl_opts, [debug_info]}.

{deps, [
    {jsx, "~> 3.0"},
    %% why: WebSocket transport for REPL protocol (ADR 0020)
    {cowboy, "2.12.0"},
    %% why: HTTP client for outbound requests (BT-1113, epic BT-1112)
    {gun, "2.1.0"},
    %% why: YAML parsing for Yaml stdlib class (BT-1122); pure Erlang, no NIFs
    {yamerl, "0.10.0"}
]}.

{profiles, [
    {test, [
        {erl_opts, [debug_info]},
        {eunit_opts, [
            {sys_config, ["apps/beamtalk_runtime/test/sys.config"]}
        ]}
    ]}
]}.

%% Compile test fixtures before running tests (portable — no bash dependency)
{pre_hooks, [
    {eunit, "escript apps/beamtalk_runtime/test_fixtures/compile_fixtures.escript"}
]}.

{eunit_opts, []}.

{cover_enabled, true}.
{cover_opts, [verbose]}.

%% Exclude Core Erlang-compiled stdlib modules from coverage reports.
%% These bt@stdlib@* BEAM files have no Erlang file attribute, so rebar3 cover
%% cannot instrument them — including them inflates the denominator without contributing to the numerator, dragging total coverage down.
{cover_excl_mods, [
    'bt@stdlib@actor',
    'bt@stdlib@array',
    'bt@stdlib@beamerror',
    'bt@stdlib@beamtalk_interface',
    'bt@stdlib@behaviour',
    'bt@stdlib@block',
    'bt@stdlib@boolean',
    'bt@stdlib@character',
    'bt@stdlib@class',
    'bt@stdlib@class_builder',
    'bt@stdlib@collection',
    'bt@stdlib@compiled_method',
    'bt@stdlib@date_time',
    'bt@stdlib@dictionary',
    'bt@stdlib@erlang',
    'bt@stdlib@erlang_module',
    'bt@stdlib@error',
    'bt@stdlib@ets',
    'bt@stdlib@exception',
    'bt@stdlib@exit_error',
    'bt@stdlib@false',
    'bt@stdlib@file',
    'bt@stdlib@file_handle',
    'bt@stdlib@float',
    'bt@stdlib@httpclient',
    'bt@stdlib@httpresponse',
    'bt@stdlib@instantiation_error',
    'bt@stdlib@integer',
    'bt@stdlib@json',
    'bt@stdlib@list',
    'bt@stdlib@metaclass',
    'bt@stdlib@number',
    'bt@stdlib@object',
    'bt@stdlib@pid',
    'bt@stdlib@port',
    'bt@stdlib@proto_object',
    'bt@stdlib@random',
    'bt@stdlib@reference',
    'bt@stdlib@regex',
    'bt@stdlib@runtime_error',
    'bt@stdlib@set',
    'bt@stdlib@stack_frame',
    'bt@stdlib@stream',
    'bt@stdlib@string',
    'bt@stdlib@subprocess',
    'bt@stdlib@symbol',
    'bt@stdlib@system',
    'bt@stdlib@test_case',
    'bt@stdlib@test_result',
    'bt@stdlib@test_runner',
    'bt@stdlib@throw_error',
    'bt@stdlib@timer',
    'bt@stdlib@transcript_stream',
    'bt@stdlib@true',
    'bt@stdlib@tuple',
    'bt@stdlib@type_error',
    'bt@stdlib@undefined_object',
    'bt@stdlib@value',
    'bt@stdlib@workspace_interface',
    'bt@stdlib@yaml',
    'bt@stdlib@reactive_subprocess',
    'bt@stdlib@os',
    'bt@stdlib@time',
    'bt@stdlib@supervisor',
    'bt@stdlib@dynamic_supervisor',
    'bt@stdlib@supervision_spec',
    'bt@stdlib@queue',
    'bt@stdlib@atomic_counter',
    'bt@stdlib@interval',
    'bt@stdlib@bag',
    'bt@stdlib@result',
    'bt@stdlib@httprequest',
    'bt@stdlib@httpserver'
]}.

{plugins, [
    covertool,
    erlfmt
]}.

%% erlfmt configuration
%% print_width 100 matches project style (same as Rust line length)
%% files uses ** glob (OTP 26+ filelib:wildcard) for umbrella apps/* layout
{erlfmt, [
    {print_width, 100},
    {files, ["apps/**/*.erl", "apps/**/*.hrl", "apps/**/*.app.src"]}
]}.

%% Dialyzer configuration
%% Focus on real errors, not overly-strict specs
{dialyzer, [
    {warnings, [
        % Warn about unhandled errors
        error_handling
        % Disabled for now (too noisy, not bugs):
        % underspecs       % Spec is supertype of inferred type
        % unmatched_returns % Expression value is unused
    ]},
    {plt_extra_apps, [jsx, yamerl, compiler, cowboy, ranch, gun, ssl, public_key]},
    %% Exclude Core Erlang-compiled stdlib modules — dialyzer cannot analyse their BEAM
    %% abstract code. The Erlang-written helper modules (beamtalk_http, etc.) are NOT
    %% excluded and remain visible to callers in beamtalk_workspace.
    {exclude_mods, [
        'bt@stdlib@actor',
        'bt@stdlib@array',
        'bt@stdlib@beamerror',
        'bt@stdlib@beamtalk_interface',
        'bt@stdlib@behaviour',
        'bt@stdlib@block',
        'bt@stdlib@boolean',
        'bt@stdlib@character',
        'bt@stdlib@class',
        'bt@stdlib@class_builder',
        'bt@stdlib@collection',
        'bt@stdlib@compiled_method',
        'bt@stdlib@date_time',
        'bt@stdlib@dictionary',
        'bt@stdlib@erlang',
        'bt@stdlib@erlang_module',
        'bt@stdlib@error',
        'bt@stdlib@exception',
        'bt@stdlib@exit_error',
        'bt@stdlib@false',
        'bt@stdlib@file',
        'bt@stdlib@file_handle',
        'bt@stdlib@float',
        'bt@stdlib@httpclient',
        'bt@stdlib@httpresponse',
        'bt@stdlib@instantiation_error',
        'bt@stdlib@integer',
        'bt@stdlib@json',
        'bt@stdlib@list',
        'bt@stdlib@metaclass',
        'bt@stdlib@number',
        'bt@stdlib@object',
        'bt@stdlib@pid',
        'bt@stdlib@port',
        'bt@stdlib@proto_object',
        'bt@stdlib@random',
        'bt@stdlib@reference',
        'bt@stdlib@regex',
        'bt@stdlib@runtime_error',
        'bt@stdlib@set',
        'bt@stdlib@stack_frame',
        'bt@stdlib@stream',
        'bt@stdlib@string',
        'bt@stdlib@subprocess',
        'bt@stdlib@symbol',
        'bt@stdlib@system',
        'bt@stdlib@test_case',
        'bt@stdlib@test_result',
        'bt@stdlib@test_runner',
        'bt@stdlib@throw_error',
        'bt@stdlib@timer',
        'bt@stdlib@transcript_stream',
        'bt@stdlib@true',
        'bt@stdlib@tuple',
        'bt@stdlib@type_error',
        'bt@stdlib@undefined_object',
        'bt@stdlib@ets',
        'bt@stdlib@value',
        'bt@stdlib@workspace_interface',
        'bt@stdlib@yaml',
        'bt@stdlib@reactive_subprocess',
        'bt@stdlib@os',
        'bt@stdlib@time',
        'bt@stdlib@supervisor',
        'bt@stdlib@dynamic_supervisor',
        'bt@stdlib@supervision_spec',
        'bt@stdlib@queue',
        'bt@stdlib@atomic_counter',
        'bt@stdlib@interval',
        'bt@stdlib@bag',
        'bt@stdlib@result',
        'bt@stdlib@httprequest',
        'bt@stdlib@httpserver'
    ]}
]}.
