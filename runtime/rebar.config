%% Umbrella project layout (ADR 0007)
{project_app_dirs, ["apps/*"]}.

{erl_opts, [debug_info]}.

{deps, [
    %% why: WebSocket transport for REPL protocol (ADR 0020)
    {cowboy, "2.12.0"},
    %% why: HTTP client for outbound requests (BT-1113, epic BT-1112)
    {gun, "2.1.0"},
    %% why: YAML parsing for Yaml stdlib class (BT-1122); pure Erlang, no NIFs
    {yamerl, "0.10.0"},
    %% why: Standard BEAM telemetry event bus for actor observability (ADR 0069)
    {telemetry, "~> 1.3"},
    %% why: Periodic VM stats (scheduler util, memory) for Tracing systemHealth (ADR 0069)
    {telemetry_poller, "~> 1.1"}
]}.

{profiles, [
    {test, [
        {erl_opts, [debug_info]},
        {eunit_opts, [
            {sys_config, ["apps/beamtalk_runtime/test/sys.config"]}
        ]}
    ]}
]}.

%% Compile test fixtures before running tests (portable — no bash dependency)
{pre_hooks, [
    {eunit, "escript apps/beamtalk_runtime/test_fixtures/compile_fixtures.escript"}
]}.

{eunit_opts, []}.

{cover_enabled, true}.
{cover_opts, [verbose]}.

%% cover_excl_mods and dialyzer exclude_mods for bt@* stdlib modules are
%% auto-generated by rebar.config.script (BT-1672). No manual list needed.

{plugins, [
    covertool,
    erlfmt
]}.

%% erlfmt configuration
%% print_width 100 matches project style (same as Rust line length)
%% files uses ** glob (OTP 26+ filelib:wildcard) for umbrella apps/* layout
{erlfmt, [
    {print_width, 100},
    {files, ["apps/**/*.erl", "apps/**/*.hrl",
             %% beamtalk_stdlib.app.src is generated by build_stdlib.rs with map syntax
             %% that erlfmt cannot parse — exclude it.
             "apps/beamtalk_compiler/src/*.app.src",
             "apps/beamtalk_runtime/src/*.app.src",
             "apps/beamtalk_workspace/src/*.app.src"]}
]}.

%% Dialyzer configuration
%% Focus on real errors, not overly-strict specs
{dialyzer, [
    {warnings, [
        % Warn about unhandled errors
        error_handling
        % Disabled for now (too noisy, not bugs):
        % underspecs       % Spec is supertype of inferred type
        % unmatched_returns % Expression value is unused
    ]},
    {plt_extra_apps, [yamerl, compiler, cowboy, ranch, gun, ssl, public_key, telemetry, telemetry_poller]}
    %% exclude_mods for bt@* modules: auto-injected by rebar.config.script (BT-1672)
]}.
