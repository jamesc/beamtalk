{application, beamtalk_runtime, [
    {description, "Beamtalk Runtime - Actor and Future implementations"},
    {vsn, {cmd, "escript ../../../scripts/version.escript"}},
    {modules, []},
    {registered, [beamtalk_classes]},
    {applications, [kernel, stdlib, telemetry, telemetry_poller]},
    {mod, {beamtalk_runtime_app, []}},
    {env, [
        {repl_port, 9000},
        {node_name, 'beamtalk@localhost'}
    ]}
]}.
