/// A simple greeting value type — canonical formatter fixture.
///
/// Demonstrates: value class with doc comment, field declaration,
/// and short single-expression methods.
Value subclass: Greeter
  field: name = "World"

  /// Returns a personalised greeting string.
  greet => "Hello, " ++ self.name ++ "!"

  /// Returns the stored name.
  name => self.name
