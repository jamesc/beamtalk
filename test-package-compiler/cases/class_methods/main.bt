// Test class method codegen (class-side methods, class variables)

Actor subclass: ClassVarCounter
  state: count = 0
  classState: instanceCount = 0

  class create =>
    self.instanceCount := self.instanceCount + 1
    self spawn

  class getCount => self.instanceCount

  increment => self.count := self.count + 1

  getCount => self.count
