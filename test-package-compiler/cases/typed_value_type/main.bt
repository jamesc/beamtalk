// Typed value type methods for spec generation

Value subclass: TypedPoint
  field: x :: Integer = 0
  field: y :: Integer = 0

  // Typed unary methods
  getX -> Integer => self.x

  getY -> Integer => self.y

  // Typed keyword method
  distanceTo: other :: TypedPoint -> Float => @primitive "distanceTo:"

  // Untyped method (no spec)
  printString => @primitive "printString"
