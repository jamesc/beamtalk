// BUnit tests for the Hello value type.
//
// Run in the REPL:
//   > :load src/hello.bt
//   > :load test/hello_test.bt
//   > HelloTest runAll

TestCase subclass: HelloTest
  class serial -> Boolean => true

  setUp =>
    self.old_ts := TranscriptStream current
    self.ts := TranscriptStream spawn
    TranscriptStream current: self.ts
    self

  tearDown =>
    TranscriptStream current: self.old_ts
    self.ts ifNotNil: [:t | t stop]
    self

  testGreeting =>
    // greeting outputs "Hello, World!" via showCr: and returns self
    Hello new greeting
    self assert: (self.ts recent includes: "Hello, World!")

  testTwoInstancesHaveSameGreeting =>
    // Both instances output the same text
    Hello new greeting
    Hello new greeting
    self assert: (self.ts recent includes: "Hello, World!")

  testClassIsHello =>
    // Hello is a value type — class name is the symbol #Hello
    self assert: Hello new class name equals: #Hello
