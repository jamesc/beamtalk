/// Simple hello world example
///
/// Try it in the REPL:
///   $ beamtalk repl
///   > :load "examples/getting-started/src/hello.bt"
///   nil
///   > Hello new greeting
///   │ Hello, World!
///   a Hello
Object subclass: Hello

  greeting => self traceCr: "Hello, World!"
