// Fixture for docs/learning/10-value-classes.md

Value subclass: Money
  field: amount = 0
  field: currency = #USD

  amount => self.amount

  currency => self.currency

  add: other =>
    other currency =:= self.currency ifFalse: [^self error: "Currency mismatch"]
    Money amount: (self.amount + other amount) currency: self.currency

  printString => "{self.amount} {self.currency}"
