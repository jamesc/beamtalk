// Typed value class fixture for docs/learning/15-type-annotations.md

typed Object subclass: Ch15TypedPoint
  state: x :: Integer = 0
  state: y :: Integer = 0

  getX -> Integer => self.x
  getY -> Integer => self.y

  distanceSquared -> Integer =>
    (self.x * self.x) + (self.y * self.y)
