/// References `Greeter` (defined in a sibling file) via a type annotation.
/// Without BT-2052's cross-file class extraction, every lint surface would
/// falsely flag `Greeter` as an unresolved class.
Object subclass: Caller

  callGreeter: g :: Greeter -> String =>
    g greet: "world"
