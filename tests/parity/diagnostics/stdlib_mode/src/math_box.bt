/// A trivial actor class referenced from a sibling test file. The BT-2027
/// regression was that linting only `test/` would lose access to this
/// definition and produce an "Unresolved class" diagnostic.
Actor subclass: MathBox
  state: value :: Integer = 0

  current -> Integer => self.value

  bump -> Integer => self.value := self.value + 1
