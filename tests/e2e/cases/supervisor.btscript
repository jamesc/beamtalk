// E2E tests for Supervisor and DynamicSupervisor supervision tree syntax (BT-1223).
//
// These tests require E2E because supervision trees manage live OTP processes.
// BUnit tests run in compiled code without access to OTP process registration,
// and cannot drive the full supervise → inspect → stop lifecycle with workspace
// variable persistence across REPL turns.
//
// ADR: docs/ADR/0059-supervision-tree-syntax.md

// @load tests/e2e/fixtures/counter.bt
// @load tests/e2e/fixtures/e2e_app_supervisor.bt
// @load tests/e2e/fixtures/e2e_worker_pool.bt
// @load tests/e2e/fixtures/e2e_inner_supervisor.bt
// @load tests/e2e/fixtures/e2e_outer_supervisor.bt
// @load tests/e2e/fixtures/e2e_stop_supervisor.bt
// @load tests/e2e/fixtures/e2e_args_supervisor.bt

// ===========================================================================
// STATIC SUPERVISOR — DISPLAY FORMAT
// ===========================================================================

// supervise returns a human-readable #Supervisor<ClassName,Pid> object (not raw tuple)
app := E2EAppSupervisor supervise
// => #Supervisor<E2EAppSupervisor,_>

// ===========================================================================
// STATIC SUPERVISOR — current
// ===========================================================================

// current returns the running supervisor instance
appCurrent := E2EAppSupervisor current
// => #Supervisor<E2EAppSupervisor,_>

// supervise is idempotent — returns the same running instance
app2 := E2EAppSupervisor supervise
// => #Supervisor<E2EAppSupervisor,_>

// ===========================================================================
// STATIC SUPERVISOR — child inspection
// ===========================================================================

// count returns the number of running children (Counter child started by OTP)
app count
// => 1

// children returns the list of child ids (Counter class name atom by default)
app children
// => ["Counter"]

// which: returns the running child actor instance
counterChild := app which: Counter
// => #Actor<Counter,_>

// the child actor responds to messages
counterChild getValue
// => 0

// ===========================================================================
// STATIC SUPERVISOR — stop and current after stop
// ===========================================================================

// stop stops the supervisor and all children, returns nil
E2EStopSupervisor supervise
// => #Supervisor<E2EStopSupervisor,_>

E2EStopSupervisor current
// => #Supervisor<E2EStopSupervisor,_>

stopSup := E2EStopSupervisor current
// => #Supervisor<E2EStopSupervisor,_>

stopSup stop
// => nil

// current returns nil after the supervisor has been stopped
E2EStopSupervisor current
// => nil

// ===========================================================================
// DYNAMIC SUPERVISOR — start and display
// ===========================================================================

// supervise returns a human-readable #DynamicSupervisor<ClassName,Pid> object
pool := E2EWorkerPool supervise
// => #DynamicSupervisor<E2EWorkerPool,_>

// count starts at 0 — no children yet
pool count
// => 0

// ===========================================================================
// DYNAMIC SUPERVISOR — startChild and terminateChild
// ===========================================================================

// startChild starts a new Counter worker under the supervisor
w1 := pool startChild
// => #Actor<Counter,_>

// count is now 1
pool count
// => 1

// start a second worker
w2 := pool startChild
// => #Actor<Counter,_>

pool count
// => 2

// terminateChild removes a child from the supervisor
pool terminateChild: w1
// => nil

pool count
// => 1

// terminate the second child too
pool terminateChild: w2
// => nil

pool count
// => 0

// ===========================================================================
// NESTED SUPERVISORS
// ===========================================================================

// E2EOuterSupervisor has E2EInnerSupervisor as its one child.
// E2EInnerSupervisor has Counter as its one child.
outer := E2EOuterSupervisor supervise
// => #Supervisor<E2EOuterSupervisor,_>

// outer has 1 child (the inner supervisor)
outer count
// => 1

// which: returns the inner supervisor as a supervisor object
innerSup := outer which: E2EInnerSupervisor
// => #Supervisor<E2EInnerSupervisor,_>

// the inner supervisor has its own Counter child
innerSup count
// => 1

// ===========================================================================
// SUPERVISIONSPEC withArgs: — spawnWith: start path
// ===========================================================================

// E2EArgsSupervisor uses SupervisionSpec withArgs: to start a Counter with
// initial value 42, exercising the spawnWith: code path in spec_to_otp.
argsSup := E2EArgsSupervisor supervise
// => #Supervisor<E2EArgsSupervisor,_>

// The supervisor has one Counter child
argsSup count
// => 1

// The child Counter was started with initial value 42 via spawnWith:
argsChild := argsSup which: Counter
// => #Actor<Counter,_>

argsChild getValue
// => 42
