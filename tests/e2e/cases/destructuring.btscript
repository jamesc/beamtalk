// E2E tests for destructuring assignment in the REPL (BT-1252).
//
// Destructuring persists all bound variables to the workspace State map,
// just like simple assignment. The display value is the original RHS.

// ===========================================================================
// LIST DESTRUCTURING — SINGLE EXPRESSION
// ===========================================================================

// #(a, b) := #(1, 2) — list pattern on a list; display is the raw list [1,2]
#(a, b) := #(1, 2)
// => [1,2]

// Variables persist across turns
a
// => 1

b
// => 2

:clear
// => ok

// Three-element list destructuring
#(x, y, z) := #(10, 20, 30)
// => [10,20,30]

x
// => 10

y
// => 20

z
// => 30

:clear
// => ok

// ===========================================================================
// ARRAY DESTRUCTURING — SINGLE EXPRESSION
// ===========================================================================

// #[x, y] := #[10, 20] — binds x and y; display is intentionally unchecked
// because the JSON representation of Beamtalk arrays is implementation-defined.
#[x, y] := #[10, 20]
// => _

x
// => 10

y
// => 20

:clear
// => ok

// ===========================================================================
// TAGGED TUPLE DESTRUCTURING
// ===========================================================================

// {#ok, val} := (tuple from FFI) — binds val; display is intentionally unchecked
// because the JSON representation of Erlang tuples is implementation-defined.
{#ok, val} := Erlang erlang list_to_tuple: #(#ok, 42)
// => _

val
// => 42

:clear
// => ok

// ===========================================================================
// MULTI-STATEMENT: DESTRUCTURING IN INTERMEDIATE POSITION
// ===========================================================================

// Destructuring in intermediate position, then use bound vars in last expr
#(a, b) := #(3, 4). a + b
// => 7

:clear
// => ok

// Array destructuring in intermediate position
#[p, q] := #[5, 6]. p + q
// => 11

:clear
// => ok

// ===========================================================================
// MULTI-STATEMENT: DESTRUCTURING IN LAST POSITION
// ===========================================================================

// Destructuring as last expression — binds vars, display is the RHS
x := 5. #(p, q) := #(x, x + 1)
// => [5,6]

p
// => 5

q
// => 6

:clear
// => ok

// ===========================================================================
// VARIABLE PERSISTENCE: DESTRUCTURED VARS USABLE IN SUBSEQUENT TURNS
// ===========================================================================

#(first, second) := #(3, 4)
// => [3,4]

first + second
// => 7

// ===========================================================================
// MUTATION-THREADED RHS (BT-1283)
//
// When the RHS of a destructuring assignment is a mutation-threaded expression
// (a loop or control-flow construct that mutates REPL-bound variables and
// therefore returns {Result, StateAcc} internally), the generated code must
// unwrap the tuple with element/2 before extracting pattern variables.
// ===========================================================================

// inject:into: with block-body mutation — single-expression turn.
// Block mutates `count`; final accumulator is #(item, count) from last iteration.
// With #(10, 20): iter1: count=1 -> #(10,1); iter2: count=2 -> #(20,2)
count := 0
// => 0

#(a, b) := #(10, 20) inject: #(0, 0) into: [:_ :item | count := count + 1. #(item, count)]
// => [20,2]

a
// => 20

b
// => 2

count
// => 2

:clear
// => ok

// inject:into: with mutation in intermediate position — bound vars usable in last expr.
// inject mutates `n`; final acc from #(5,15) is #(15,2): x=15, y=2, x+y=17.
n := 0. #(x, y) := #(5, 15) inject: #(0, 0) into: [:_ :item | n := n + 1. #(item, n)]. x + y
// => 17

:clear
// => ok

// inject:into: with mutation in last position — binds and persists across turns.
m := 0
// => 0

m := 0. #(p, q) := #(3, 7) inject: #(0, 0) into: [:_ :item | m := m + 1. #(item, m)]
// => [7,2]

p
// => 7

q
// => 2

m
// => 2

:clear
// => ok

// ===========================================================================
// REASSIGNMENT AFTER DESTRUCTURING (BT-1483)
//
// Destructured bindings must not leak into the persistent REPL scope.
// After `a := 99`, reading `a` must return 99, not the stale value from
// the destructured pattern.
// ===========================================================================

#[a] := #[1, 2]. a := 99. a
// => 99

:clear
// => ok

// Same bug across turns — reassignment in a later turn must override.
#(x, y) := #(10, 20)
// => [10,20]

x := 99
// => 99

x
// => 99
