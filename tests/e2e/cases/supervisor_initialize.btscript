// E2E tests for Supervisor and DynamicSupervisor initialize: lifecycle hook (BT-1542).
//
// Verifies that:
// 1. initialize: runs after all children have started
// 2. The supervisor is responsive during initialize: (no deadlock)
// 3. which: and startChild work inside the callback

// @load tests/e2e/fixtures/counter.bt
// @load tests/e2e/fixtures/e2e_init_child_a.bt
// @load tests/e2e/fixtures/e2e_init_child_b.bt
// @load tests/e2e/fixtures/e2e_init_supervisor.bt
// @load tests/e2e/fixtures/e2e_init_dyn_supervisor.bt

// ===========================================================================
// STATIC SUPERVISOR — initialize: calls which: on a sibling
// ===========================================================================

// supervise starts all children, then runs initialize:
sup := (E2EInitSupervisor supervise) unwrap
// => #Supervisor<E2EInitSupervisor,_>

// Both children are alive
sup count
// => 2

// initialize: called which: on E2EInitChildA and set its value to 42
childA := sup which: E2EInitChildA
// => #Actor<E2EInitChildA,_>

childA getValue
// => 42

// ChildB was not modified by initialize:
childB := sup which: E2EInitChildB
// => #Actor<E2EInitChildB,_>

childB getValue
// => 0

// Idempotent supervise does NOT re-run initialize:
sup2 := (E2EInitSupervisor supervise) unwrap
// => #Supervisor<E2EInitSupervisor,_>

// setValue: 42 was called once during the first supervise; a second supervise
// should not replay it. If it did, the value would still be 42 (same effect),
// so we verify count is still 2 — no extra children or side effects.
sup2 count
// => 2

sup stop
// => nil

// ===========================================================================
// DYNAMIC SUPERVISOR — initialize: calls startChild
// ===========================================================================

// supervise starts, then initialize: pre-populates with 2 children
pool := (E2EInitDynSupervisor supervise) unwrap
// => #DynamicSupervisor<E2EInitDynSupervisor,_>

// initialize: called startChild twice
pool count
// => 2

// Idempotent supervise does NOT re-run initialize: (would add 2 more children)
pool2 := (E2EInitDynSupervisor supervise) unwrap
// => #DynamicSupervisor<E2EInitDynSupervisor,_>

pool2 count
// => 2

pool stop
// => nil

// ===========================================================================
// DEFAULT initialize: — supervisor without override works normally
// ===========================================================================

// E2EAppSupervisor has no initialize: override — default no-op
app := (E2EAppSupervisor supervise) unwrap
// => #Supervisor<E2EAppSupervisor,_>

app count
// => 1

app stop
// => nil
