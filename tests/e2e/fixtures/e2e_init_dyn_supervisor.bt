// E2E fixture: DynamicSupervisor with initialize: hook that pre-populates (BT-1542).
// initialize: calls startChild — verifies supervisor is responsive during callback.

DynamicSupervisor(Counter) subclass: E2EInitDynSupervisor

  class childClass => Counter

  class initialize: sup =>
    sup startChild
    sup startChild
