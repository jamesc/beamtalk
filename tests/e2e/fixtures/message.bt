// Message value type fixture for E2E tests (BT-568)
// Demonstrates: value types (Value subclass), immutable data, new: initialization

Value subclass: Message
  field: text = ""
  field: sender = "Anonymous"

  getText => self.text

  getSender => self.sender

  printString => self.sender ++ ": " ++ self.text
