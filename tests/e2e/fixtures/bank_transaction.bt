// Transaction fixture for E2E tests (BT-569)
// Immutable value type recording a completed transfer

Value subclass: Transaction
  field: amount = 0
  field: from = ""
  field: to = ""
  field: timestamp = nil
  field: status = "pending"

  getAmount => self.amount

  getFrom => self.from

  getTo => self.to

  getTimestamp => self.timestamp

  getStatus => self.status
