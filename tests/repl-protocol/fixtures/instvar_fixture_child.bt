// BT-2208: Subclass fixture for SystemNavigation instVarReadersOf:in: /
// instVarWritersOf:in: E2E tests. See instvar_fixture.bt for the parent.
//
// `InstVarChild` inherits the `tally` slot from `InstVarFixture` and defines a
// method that reads AND writes it. This validates that instVarReadersOf:in: /
// instVarWritersOf:in: walk `aClass allSubclasses` (a subclass inherits the
// slot, so its own methods can read/write it).
//
// STABLE — do not rename the method or edit its body (BT-2208).

InstVarFixture subclass: InstVarChild

  // Reads AND writes the inherited `tally` slot.
  childBump => self.tally := self.tally + 2
