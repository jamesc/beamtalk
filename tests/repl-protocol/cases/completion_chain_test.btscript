// E2E tests for REPL chain-resolution completion (BT-1007).
//
// Chain resolution: when the user types `"hello" size <TAB>`, the REPL should
// infer that `size` returns an Integer (via return-type annotation on String>>size)
// and offer Integer methods as completions.

// @load tests/repl-protocol/fixtures/typed_counter.bt

// ===========================================================================
// CHAIN COMPLETION — String literal receiver
// ===========================================================================

// `"hello" size <TAB>` — size returns Integer, so Integer methods should appear.
:complete "hello" size
// => INCLUDES:abs

// ===========================================================================
// CHAIN COMPLETION — broken chain (unknown selector)
// ===========================================================================

// An unknown selector (not an existing atom) breaks the chain → empty completions.
:complete "hello" xNoSuchMethodAtom
// =>

// ===========================================================================
// SINGLE-TOKEN FALLBACK — unaffected by chain resolution
// ===========================================================================

// Single-token `"hello" ` (no send chain) → String instance methods (unchanged).
:complete "hello"
// => INCLUDES:size

// ===========================================================================
// CHAIN COMPLETION — user-defined actor with return type annotation
// ===========================================================================

// Spawn a TypedCounter to create a binding (tc) that completions can resolve.
tc := TypedCounter spawn
// => _

// `tc getValue ` — getValue is annotated `-> Integer`, so Integer methods appear.
:complete tc getValue
// => INCLUDES:abs

// `tc ` — single-token actor binding → TypedCounter instance methods (not chain).
:complete tc
// => INCLUDES:getValue

// ===========================================================================
// PAREN SUBEXPRESSION AS RECEIVER (BT-1070)
// ===========================================================================

// `("foo" ++ "bar") <TAB>` — paren binary-send resolves to String via compiler.
:complete ("foo" ++ "bar")
// => INCLUDES:size

// `("foo" ++ "bar") size <TAB>` — chain through compiler: String>>size → Integer.
:complete ("foo" ++ "bar") size
// => INCLUDES:abs

// `(myList size) <TAB>` — myList is untyped (Dynamic), graceful fallback: no completions.
:complete (myList size)
// =>

// ===========================================================================
// KEYWORD SENDS MID-CHAIN (BT-1072)
// ===========================================================================

// `#[1, 2, 3] collect: [:x | x * 2] <TAB>` — Array#collect: returns Array → offer Array methods.
:complete #[1, 2, 3] collect: [:x | x * 2]
// => INCLUDES:size

// `#[1, 2, 3] inject: 0 into: [...] <TAB>` — BT-1834: inject:into: resolves accumulator type A
// from initial value (0 → Integer), so completions show Integer methods.
:complete #[1, 2, 3] inject: 0 into: [:acc :x | acc + x]
// => INCLUDES:isEven

// `myList collect: [:x | x] <TAB>` — myList is untyped (Dynamic) → graceful fallback.
:complete myList collect: [:x | x]
// =>

// ===========================================================================
// TYPE-ANNOTATION-POSITION COMPLETION — class/protocol + alias names (BT-2918)
// ===========================================================================
//
// Immediately after `::`, the live `complete` op now offers class/protocol
// names — same as the static LSP path — plus this session's live type
// alias names (ADR 0108 Phase 8), the live-REPL counterpart to
// completion_provider.rs's add_alias_name_completions (BT-2901).
//
// get_completions() (the harness helper behind `:complete`) always appends a
// trailing space to simulate pressing TAB right after the last full token —
// needed so chain-resolution cases above (`"hello" size <TAB>`) distinguish
// "complete on the *result* of size" from "complete String methods starting
// with size". That convention means a *partial* type name typed right after
// `::` (no space) can't be exercised through this harness — the appended
// space would land inside the receiver expression instead of after `::`,
// same as it would for any other in-progress token. Empty prefix (bare
// `::<TAB>`, nothing typed yet) is unaffected and still exercises annotation-
// position detection precisely — see beamtalk_repl_ops_dev_tests.erl's
// type_annotation_completion_* tests for partial-prefix filtering coverage.

// A live class name is offered in annotation position.
:complete restartPolicy ::
// => INCLUDES:Integer

// A session-declared type alias, from an earlier turn, joins class/protocol
// names in the same position.
type RestartStrategy = #permanent | #transient | #temporary
// => RestartStrategy

:complete restartPolicy ::
// => INCLUDES:RestartStrategy
