// E2E tests for the Inspector's value `evaluate:` and collection navigation
// (ADR 0095 Phase 2, BT-2503).
//
// These require E2E because value `evaluate:` compiles the expression with
// `self` bound to the inspected value through the live compiler port, which the
// BUnit harness does not start (see stdlib/test/inspector_test.bt for the
// contract-only coverage there). Collection windowing/`page:`/`at:` are checked
// here end-to-end alongside it.

// @load tests/repl-protocol/fixtures/point.bt
// @load tests/repl-protocol/fixtures/counter.bt

// ===========================================================================
// VALUE evaluate: — `self` bound to the inspected value (ADR 0095 §1, §7)
// ===========================================================================

i := Inspector on: (Point x: 3 y: 4)
// => _

(i evaluate: "self x + self y") unwrap
// => 7

(i evaluate: "self x * 10") unwrap
// => 30

// A failure in the expression is a Result error:, never a crash.
(i evaluate: "self nonesuchMessage") isError
// => true

// ---------------------------------------------------------------------------
// Drilling yields a #value cursor on the scalar; `self` is that scalar.
// ---------------------------------------------------------------------------

child := (i at: #x) unwrap
// => _

(child evaluate: "self + 100") unwrap
// => 103

// ===========================================================================
// COLLECTION windowing, page:, direct-index at: (ADR 0095 §6)
// ===========================================================================

big := Inspector on: ((1 to: 1000) asList)
// => _

big size
// => 1000

big fields size
// => 50

(big page: 2) unwrap fields first value
// => 51

(big at: 73) unwrap subject
// => 73

// ===========================================================================
// `inspect` shorthand + asDictionaries / asDictionary wire form
// (ADR 0095 §1, §7, Phase 3 BT-2504)
// ===========================================================================

// `anObject inspect` is the shorthand for `Inspector on: anObject` and returns
// an Inspector cursor (the breaking repurpose from `-> String`).
(Point x: 3 y: 4) inspect kind
// => value

(Point x: 3 y: 4) inspect fields size
// => 2

// printString remains the structural Debug string (the old inspect result).
(Point x: 3 y: 4) printString
// => Point(x: 3, y: 4)

// asDictionaries: one dictionary per field, carrying the typed record.
((Point x: 3 y: 4) inspect asDictionaries) size
// => 2

(((Point x: 3 y: 4) inspect asDictionaries) detect: [:d | (d at: #name) == #x]) at: #value
// => 3

// asDictionary: the cursor envelope with kind / childCount / page / fields.
(((1 to: 1000) asList inspect) asDictionary) at: #childCount
// => 1000

(((1 to: 1000) asList inspect) asDictionary) at: #page
// => 1

((((1 to: 1000) asList inspect) asDictionary) at: #fields) size
// => 50

// ===========================================================================
// inspect → drill → refresh, end-to-end against a VALUE and a live ACTOR
// (ADR 0095 Phase 4, BT-2505)
// ===========================================================================

// --- VALUE: inspect → render → drill ---
p := (Point x: 3 y: 4) inspect
// => _

p kind
// => value

// printString renders the class-headed text tree with immediate fields.
p printString includesSubstring: "Inspector(Point)"
// => true

p printString includesSubstring: "x: 3"
// => true

// Drill into a field → a child cursor on that value; the root path stays empty.
(p at: #x) unwrap subject
// => 3

p path
// => []

// --- ACTOR: inspect captures a live snapshot; refresh re-snapshots ---
c := Counter spawn
// => Actor(Counter, _)

c increment
// => 1

c increment
// => 2

// `c inspect` runs inside the actor and seeds the cursor from its in-hand state
// (no self-`sys:get_state` deadlock) — the snapshot shows value 2.
ci := c inspect
// => _

ci kind
// => actor

ci printString includesSubstring: "value: 2"
// => true

// The snapshot is frozen at inspect-time: mutating the actor does not change it.
c increment
// => 3

ci printString includesSubstring: "value: 2"
// => true

// refresh re-issues the guarded snapshot from outside the actor — now value 3.
ci refresh printString includesSubstring: "value: 3"
// => true

// asDictionary envelope reports the cursor kind for the MCP/browser surfaces.
(c inspect asDictionary) at: #kind
// => actor
