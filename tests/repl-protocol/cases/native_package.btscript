// E2E tests for native package build and REPL load (ADR 0072 Phase 5, BT-1719).
//
// Tests the full native package workflow:
//   1. Load a .bt class from a package with native/ Erlang sources
//   2. Demand-driven native compilation (BT-1717) compiles the .erl
//   3. FFI calls to the native module work correctly
//   4. Modify the .erl source, reload, verify new behaviour
//
// The fixture project lives at tests/repl-protocol/fixtures/native_package_project/
// with this layout:
//   beamtalk.toml
//   src/NativeCalc.bt          — Beamtalk class using (Erlang native_calc) FFI
//   native/native_calc.erl     — user-authored Erlang module

// ===========================================================================
// LOAD NATIVE-BACKED CLASS FROM PACKAGE
// ===========================================================================

// Load the .bt class; demand-driven compilation handles native/native_calc.erl
:load tests/repl-protocol/fixtures/native_package_project/src/NativeCalc.bt
// => Loaded: NativeCalc

// ===========================================================================
// VERIFY FFI DISPATCH TO NATIVE MODULE
// ===========================================================================

// Class method calling native Erlang add/2
NativeCalc add: 3 with: 4
// => 7

// Class method calling native Erlang multiply/2
NativeCalc multiply: 6 with: 7
// => 42

// Zero-arg class method calling native Erlang version/0
NativeCalc version
// => 1

// ===========================================================================
// INCREMENTAL RELOAD: MODIFY .ERL, RELOAD, VERIFY NEW BEHAVIOUR
// ===========================================================================

// Save the path to the native .erl file for modification
erlPath := "tests/repl-protocol/fixtures/native_package_project/native/native_calc.erl"
// => _

// Save original content so we can restore it after the test
originalContent := (File readAll: erlPath) unwrap
// => _

// Write a modified version: version/0 now returns 2 instead of 1
modifiedContent := originalContent replaceAll: "version() -> 1." with: "version() -> 2."
// => _

File writeAll: erlPath contents: modifiedContent
// => _

// Reload the class — demand-driven compilation detects the stale .erl
:reload NativeCalc
// => NativeCalc

// Verify the recompiled native module reflects the change
NativeCalc version
// => 2

// Arithmetic methods still work after reload
NativeCalc add: 10 with: 20
// => 30

// ===========================================================================
// CLEANUP: RESTORE ORIGINAL .ERL FILE
// ===========================================================================

// Restore original content so the fixture is clean for the next test run.
// We write the file but skip reload verification — the mtime granularity
// (1 second on most filesystems) can prevent stale detection when the
// restore and reload happen within the same second.
File writeAll: erlPath contents: originalContent
// => _
