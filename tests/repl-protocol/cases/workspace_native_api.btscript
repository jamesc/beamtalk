// E2E tests for Beamtalk-native workspace API (BT-849 / ADR 0040 Phase 6).
//
// Tests that the Beamtalk-native message-send forms work correctly
// alongside and as alternatives to the deprecated protocol ops and
// REPL `:` shortcut commands.
//
// Native API:
//   Workspace load: "path"   (replaces load-file protocol op / :load alias)
//   Workspace classes         (lists loaded classes)
//   Counter reload            (replaces reload protocol op / :reload alias)
//   Beamtalk help: Class      (replaces docs protocol op / :help command)
//   Beamtalk help: Class selector: #sel  (replaces docs with selector)
//   Beamtalk version          (informational)
//   Beamtalk allClasses       (class registry inspection)
//   Beamtalk classNamed:      (class lookup by name)
//   Beamtalk globals          (global namespace snapshot)

// ===========================================================================
// BEAMTALK VERSION
// ===========================================================================

// Beamtalk version returns a non-empty string
v := Beamtalk version
// => _

v isEmpty
// => false

// ===========================================================================
// BEAMTALK ALLCLASSES
// ===========================================================================

// allClasses returns a list of class objects
classes := Beamtalk allClasses
// => _

// allClasses includes known stdlib classes (as class objects)
classes includes: Integer
// => true

classes includes: String
// => true

classes includes: Actor
// => true

// class objects in allClasses respond to name
classes first respondsTo: #name
// => true

// ===========================================================================
// BEAMTALK CLASSNAMED:
// ===========================================================================

// classNamed: returns the Integer class object
Beamtalk classNamed: #Integer
// => Integer

// classNamed: returns nil for unknown classes
Beamtalk classNamed: #NoSuchClassXyzzy
// => nil

// ===========================================================================
// BEAMTALK GLOBALS
// ===========================================================================

// Beamtalk globals returns a Dictionary snapshot
btGlobals := Beamtalk globals
// => _

// globals includes core stdlib classes
btGlobals includesKey: #Integer
// => true

btGlobals includesKey: #String
// => true

// ===========================================================================
// BEAMTALK HELP: — native equivalent of :help / docs protocol op
// ===========================================================================

// Beamtalk help: returns documentation for a class
helpText := Beamtalk help: Integer
// => _

helpText isNil
// => false

// Beamtalk help:selector: returns documentation for a specific method
methodHelpText := Beamtalk help: Integer selector: #+
// => _

methodHelpText isNil
// => false

// help: and :help produce similar output (both show class header)
// :help Integer also shows the class header
:help Integer
// => == Integer < Number ==_

// ===========================================================================
// WORKSPACE CLASSES — list loaded classes
// ===========================================================================

// Load a fixture class
:load tests/repl-protocol/fixtures/counter.bt
// => _

// Workspace classes includes the loaded Counter class
wsClasses := Workspace classes
// => _

wsClasses includes: Counter
// => true

// ===========================================================================
// WORKSPACE LOAD: — native equivalent of :load / load-file protocol op
// ===========================================================================

// Load using native Workspace load: message send
Workspace load: "tests/repl-protocol/fixtures/reload_counter.bt"
// => ["ReloadCounter"]

// After loading, the class is available and has a sourceFile
ReloadCounter sourceFile
// => tests/repl-protocol/fixtures/reload_counter.bt

// ===========================================================================
// BEHAVIOUR RELOAD — native equivalent of :reload / reload protocol op
// ===========================================================================

// Spawn an actor before reload
rc := ReloadCounter spawn
// => #Actor<ReloadCounter,_>

rc increment
// => 1

// Reload using native ClassName reload message send
ReloadCounter reload
// => ReloadCounter

// Actor still works after reload
rc increment
// => 2

// ===========================================================================
// WORKSPACE GLOBALS — project namespace snapshot
// ===========================================================================

// Workspace globals includes Workspace, Beamtalk, Transcript
wsGlobals := Workspace globals
// => _

wsGlobals includesKey: #Workspace
// => true

wsGlobals includesKey: #Beamtalk
// => true

// Workspace globals also includes loaded user classes
wsGlobals includesKey: #Counter
// => true

// ===========================================================================
// SYSTEMNAVIGATION IMPLEMENTORSOF: — find classes that locally define a selector
// (BT-2214; originally added on Beamtalk in BT-2189, moved here in BT-2214)
// ===========================================================================

// implementorsOf: returns a non-empty list for a widely-implemented selector
asStringImpls := SystemNavigation default implementorsOf: #asString
// => _

asStringImpls isEmpty
// => false

// Stdlib classes participate — Integer/Float/String all locally define asString
asStringImpls includes: Integer
// => true

asStringImpls includes: String
// => true

asStringImpls includes: Float
// => true

// User-loaded classes show up in results when they implement the selector.
// Counter (loaded above) locally defines #increment.
(SystemNavigation default implementorsOf: #increment) includes: Counter
// => true

// Selectors with no implementors return an empty list
SystemNavigation default implementorsOf: #thisSelectorIsNotDefinedAnywhereXyzzy
// => []

// implementorsOf: does NOT walk inheritance — #class is defined on
// ProtoObject; Integer inherits it but is not an implementor.
classImpls := SystemNavigation default implementorsOf: #class
// => _

classImpls includes: Integer
// => false

// implementorsOf: also finds class-side implementors as metaclass objects.
// `Bag` defines `class withAll:` — that hit appears as `Bag class`.
withAllImpls := SystemNavigation default implementorsOf: #withAll:
// => _

withAllImpls includes: Bag class
// => true

// superclassChain works on metaclass receivers — walks the parallel hierarchy.
// Counter class superclassChain => [Counter class, Actor class, Object class]
metaChain := Counter class superclassChain
// => _

metaChain first
// => Counter class

metaChain last
// => Object class

metaChain size
// => 3

// ===========================================================================
// SYSTEMNAVIGATION SENDERSOF: — find call sites of a selector
// (BT-2214; originally added on Beamtalk in BT-2190, moved here in BT-2214)
// ===========================================================================

// sendersOf: returns a non-empty list for a widely-sent binary selector.
// Counter (loaded above) sends `+` from `increment`, so `+` must have
// at least one sender in a workspace that has Counter loaded.
plusSenders := SystemNavigation default sendersOf: #+
// => _

plusSenders isEmpty
// => false

// Each record is a Dictionary with #class, #selector, #line keys.
plusRecord := plusSenders first
// => _

plusRecord includesKey: #class
// => true

plusRecord includesKey: #selector
// => true

plusRecord includesKey: #line
// => true

// Counter >> #increment sends `+` — assert by collecting all class atoms
// from the senders and checking Counter appears (avoids in-block equality
// against a class reference, which the multi-line REPL parser does not
// terminate predictably).
plusClassList := plusSenders collect: [:r | r at: #class]
// => _

plusClassList includes: Counter
// => true

// At least one of those records names the `increment` method.
plusSelectorList := plusSenders collect: [:r | r at: #selector]
// => _

plusSelectorList includes: #increment
// => true

// Line numbers are 1-based positive integers.
plusLineList := plusSenders collect: [:r | r at: #line]
// => _

plusLineList allSatisfy: [:n | n > 0]
// => true

// sendersOf: with a selector that nobody sends returns an empty list.
SystemNavigation default sendersOf: #neverCalledByAnybodyXyzzy
// => []

// Symbol argument is required — passing a String raises a useful error.
[SystemNavigation default sendersOf: "+"] on: Error do: [:e | #ok]
// => ok
