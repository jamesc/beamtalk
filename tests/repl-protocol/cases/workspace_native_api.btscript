// E2E tests for Beamtalk-native workspace API (BT-849 / ADR 0040 Phase 6).
//
// Tests that the Beamtalk-native message-send forms work correctly
// alongside and as alternatives to the deprecated protocol ops and
// REPL `:` shortcut commands.
//
// Native API:
//   Workspace load: "path"   (replaces load-file protocol op / :load alias)
//   Workspace classes         (lists loaded classes)
//   Counter reload            (replaces reload protocol op / :reload alias)
//   Beamtalk help: Class      (replaces docs protocol op / :help command)
//   Beamtalk help: Class selector: #sel  (replaces docs with selector)
//   Beamtalk version          (informational)
//   Beamtalk allClasses       (class registry inspection)
//   Beamtalk classNamed:      (class lookup by name)
//   Beamtalk globals          (global namespace snapshot)

// ===========================================================================
// BEAMTALK VERSION
// ===========================================================================

// Beamtalk version returns a non-empty string
v := Beamtalk version
// => _

v isEmpty
// => false

// ===========================================================================
// BEAMTALK ALLCLASSES
// ===========================================================================

// allClasses returns a list of class objects
classes := Beamtalk allClasses
// => _

// allClasses includes known stdlib classes (as class objects)
classes includes: Integer
// => true

classes includes: String
// => true

classes includes: Actor
// => true

// class objects in allClasses respond to name
classes first respondsTo: #name
// => true

// ===========================================================================
// BEAMTALK CLASSNAMED:
// ===========================================================================

// classNamed: returns the Integer class object
Beamtalk classNamed: #Integer
// => Integer

// classNamed: returns nil for unknown classes
Beamtalk classNamed: #NoSuchClassXyzzy
// => nil

// ===========================================================================
// BEAMTALK GLOBALS
// ===========================================================================

// Beamtalk globals returns a Dictionary snapshot
btGlobals := Beamtalk globals
// => _

// globals includes core stdlib classes
btGlobals includesKey: #Integer
// => true

btGlobals includesKey: #String
// => true

// ===========================================================================
// BEAMTALK HELP: — native equivalent of :help / docs protocol op
// ===========================================================================

// Beamtalk help: returns documentation for a class
helpText := Beamtalk help: Integer
// => _

helpText isNil
// => false

// Beamtalk help:selector: returns documentation for a specific method
methodHelpText := Beamtalk help: Integer selector: #+
// => _

methodHelpText isNil
// => false

// help: and :help produce similar output (both show class header)
// :help Integer also shows the class header
:help Integer
// => == Integer < Number ==_

// ===========================================================================
// WORKSPACE CLASSES — list loaded classes
// ===========================================================================

// Load a fixture class
:load tests/repl-protocol/fixtures/counter.bt
// => _

// Workspace classes includes the loaded Counter class
wsClasses := Workspace classes
// => _

wsClasses includes: Counter
// => true

// ===========================================================================
// WORKSPACE LOAD: — native equivalent of :load / load-file protocol op
// ===========================================================================

// Load using native Workspace load: message send
Workspace load: "tests/repl-protocol/fixtures/reload_counter.bt"
// => ["ReloadCounter"]

// After loading, the class is available and has a sourceFile
ReloadCounter sourceFile
// => tests/repl-protocol/fixtures/reload_counter.bt

// ===========================================================================
// BEHAVIOUR RELOAD — native equivalent of :reload / reload protocol op
// ===========================================================================

// Spawn an actor before reload
rc := ReloadCounter spawn
// => #Actor<ReloadCounter,_>

rc increment
// => 1

// Reload using native ClassName reload message send
ReloadCounter reload
// => ReloadCounter

// Actor still works after reload
rc increment
// => 2

// ===========================================================================
// WORKSPACE GLOBALS — project namespace snapshot
// ===========================================================================

// Workspace globals is a live BindingsView over the workspace singletons +
// bind:as: layer (ADR 0081). It includes the singletons Workspace, Beamtalk,
// Transcript, but NOT the class registry — classes live in Beamtalk globals.
wsGlobals := Workspace globals
// => _

wsGlobals includesKey: #Workspace
// => true

wsGlobals includesKey: #Beamtalk
// => true

// Loaded user classes are NOT in Workspace globals (they are in Beamtalk
// globals, the class registry — a separate layer per ADR 0081).
wsGlobals includesKey: #Counter
// => false

// The class registry (Beamtalk globals) is where the Counter class lives.
(Beamtalk globals) includesKey: #Counter
// => true

// ===========================================================================
// SYSTEMNAVIGATION IMPLEMENTORSOF: — find classes that locally define a selector
// (BT-2214; originally added on Beamtalk in BT-2189, moved here in BT-2214)
// ===========================================================================

// Load the stable fixture classes for SystemNavigation tests (BT-2220).
// These give us controlled, test-owned classes/selectors so assertions do
// not depend on live stdlib content that may churn across unrelated edits.
:load tests/repl-protocol/fixtures/sysnavigation_fixture.bt
// => _

:load tests/repl-protocol/fixtures/sysnavigation_fixture_b.bt
// => _

// implementorsOf: returns a non-empty list for a selector with known implementors.
// SysnavFixture and SysnavFixtureB both define #asString locally (see fixture),
// so the result must include at least these two fixture-controlled classes.
asStringImpls := SystemNavigation default implementorsOf: #asString
// => _

asStringImpls isEmpty
// => false

// Fixture-controlled: SysnavFixture locally defines #asString.
asStringImpls includes: SysnavFixture
// => true

// Fixture-controlled: SysnavFixtureB also locally defines #asString.
asStringImpls includes: SysnavFixtureB
// => true

// User-loaded classes show up in results when they implement the selector.
// Counter (loaded above) locally defines #increment.
(SystemNavigation default implementorsOf: #increment) includes: Counter
// => true

// Selectors with no implementors return an empty list
SystemNavigation default implementorsOf: #thisSelectorIsNotDefinedAnywhereXyzzy
// => []

// implementorsOf: does NOT walk inheritance — #class is defined on
// ProtoObject; Integer inherits it but is not an implementor.
classImpls := SystemNavigation default implementorsOf: #class
// => _

classImpls includes: Integer
// => false

// implementorsOf: also finds class-side implementors as metaclass objects.
// `SystemNavigation class` defines `class default` — that hit appears as
// `SystemNavigation class` (the metaclass object). This is a stable fixture
// anchor: `default` is a class-side method on SystemNavigation itself, which
// is the feature under test, so it cannot disappear without breaking this suite.
withDefaultImpls := SystemNavigation default implementorsOf: #default
// => _

withDefaultImpls includes: SystemNavigation class
// => true

// superclassChain works on metaclass receivers — walks the parallel hierarchy.
// Counter class superclassChain => [Counter class, Actor class, Object class]
metaChain := Counter class superclassChain
// => _

metaChain first
// => Counter class

metaChain last
// => Object class

metaChain size
// => 3

// ===========================================================================
// SYSTEMNAVIGATION SENDERSOF: — find call sites of a selector
// (BT-2214; originally added on Beamtalk in BT-2190, moved here in BT-2214)
// ===========================================================================

// sendersOf: returns a non-empty list for a widely-sent binary selector.
// Counter (loaded above) sends `+` from `increment`, so `+` must have
// at least one sender in a workspace that has Counter loaded.
plusSenders := SystemNavigation default sendersOf: #+
// => _

plusSenders isEmpty
// => false

// Each record is a Dictionary with #class, #selector, #line keys.
plusRecord := plusSenders first
// => _

plusRecord includesKey: #class
// => true

plusRecord includesKey: #selector
// => true

plusRecord includesKey: #line
// => true

// Counter >> #increment sends `+` — assert by collecting all class atoms
// from the senders and checking Counter appears (avoids in-block equality
// against a class reference, which the multi-line REPL parser does not
// terminate predictably).
plusClassList := plusSenders collect: [:r | r at: #class]
// => _

plusClassList includes: Counter
// => true

// At least one of those records names the `increment` method.
plusSelectorList := plusSenders collect: [:r | r at: #selector]
// => _

plusSelectorList includes: #increment
// => true

// Line numbers are 1-based positive integers.
plusLineList := plusSenders collect: [:r | r at: #line]
// => _

plusLineList allSatisfy: [:n | n > 0]
// => true

// sendersOf: with a selector that nobody sends returns an empty list.
SystemNavigation default sendersOf: #neverCalledByAnybodyXyzzy
// => []

// Symbol argument is required — passing a String raises a useful error.
[SystemNavigation default sendersOf: "+"] on: Error do: [:e | #ok]
// => ok

// BT-2195: Class-side method bodies participate. `SystemNavigation class
// >> #default` is a class-side method that sends `new`, so the senders of
// `#new` must include a hit whose `#class` is `SystemNavigation class`
// (the metaclass object), not `SystemNavigation`. Confirms the walker
// recurses through `cls class` as well as `cls`, and that the metaclass
// object is what shows up in the record.
newSenders := SystemNavigation default sendersOf: #new
// => _

newSenderClasses := newSenders collect: [:r | r at: #class]
// => _

newSenderClasses includes: SystemNavigation class
// => true

// BT-2196: Extension method bodies registered via `register/5` (with source)
// are scanned by `sendersOf:` alongside class-body methods. Register an
// extension whose body sends a uniquely-named selector, then assert
// `sendersOf:` finds it. Cleans up both ETS tables.
extSendersFun := [:a :s | s]
// => _

extSendersSource := "describe => self btTwoTwoOneSixSrcSenderMarker"
// => _

Erlang beamtalk_extensions register: #Integer selector: #btTwoTwoOneSixSrcSenderExt fun: extSendersFun owner: #test source: extSendersSource
// => _

extSenderHits := SystemNavigation default sendersOf: #btTwoTwoOneSixSrcSenderMarker
// => _

(extSenderHits collect: [:r | r at: #selector]) includes: #btTwoTwoOneSixSrcSenderExt
// => true

Erlang ets delete: #beamtalk_extensions key: #(#Integer, #btTwoTwoOneSixSrcSenderExt)
// => _

Erlang ets delete: #beamtalk_extension_sources key: #(#Integer, #btTwoTwoOneSixSrcSenderExt)
// => _

// BT-2196: Extensions registered via the legacy `register/4` (no source)
// stay invisible to `sendersOf:` — there is no body text to grep.
extBareSendersFun := [:a :s | s]
// => _

Erlang beamtalk_extensions register: #Integer selector: #btTwoTwoOneSixBareSenderExt fun: extBareSendersFun owner: #test
// => _

extBareSenderHits := SystemNavigation default sendersOf: #btTwoTwoOneSixSrcSenderMarker
// => _

(extBareSenderHits collect: [:r | r at: #selector]) includes: #btTwoTwoOneSixBareSenderExt
// => false

Erlang ets delete: #beamtalk_extensions key: #(#Integer, #btTwoTwoOneSixBareSenderExt)
// => _

// BT-2196: A class-side extension (registered under the `#'Integer class'`
// metaclass tag) reports the metaclass OBJECT in `#class`, matching the
// shape BT-2195's class-side method walk emits — not the raw atom. This is
// the parity guarantee `resolveExtensionClass:` provides: callers can
// compare `record at: #class` against `Integer class` directly.
extMetaFun := [:a :s | s]
// => _

extMetaSource := "describe => self btTwoTwoOneSixMetaSenderMarker"
// => _

Erlang beamtalk_extensions register: #'Integer class' selector: #btTwoTwoOneSixMetaSenderExt fun: extMetaFun owner: #test source: extMetaSource
// => _

extMetaHits := SystemNavigation default sendersOf: #btTwoTwoOneSixMetaSenderMarker
// => _

(extMetaHits collect: [:r | r at: #class]) includes: Integer class
// => true

Erlang ets delete: #beamtalk_extensions key: #(#'Integer class', #btTwoTwoOneSixMetaSenderExt)
// => _

Erlang ets delete: #beamtalk_extension_sources key: #(#'Integer class', #btTwoTwoOneSixMetaSenderExt)
// => _

// ===========================================================================
// SYSTEMNAVIGATION REFERENCESTO: — find class-reference sites (BT-2203)
// ===========================================================================

// referencesTo: returns a non-empty list for a class that the loaded fixture
// references by name. SysnavFixture >> #btReferencesFixture contains the
// literal class name `SysnavFixture` in its body, so referencesTo: must find
// at least one hit. This avoids depending on stdlib mentioning Integer
// (fragile to stdlib churn — BT-2220).
fixtureRefs := SystemNavigation default referencesTo: SysnavFixture
// => _

fixtureRefs isEmpty
// => false

// Each record is a Dictionary with #class, #selector, #line keys —
// same shape as sendersOf:.
fixtureRecord := fixtureRefs first
// => _

fixtureRecord includesKey: #class
// => true

fixtureRecord includesKey: #selector
// => true

fixtureRecord includesKey: #line
// => true

// Line numbers are 1-based positive integers.
fixtureLineList := fixtureRefs collect: [:r | r at: #line]
// => _

fixtureLineList allSatisfy: [:n | n > 0]
// => true

// referencesTo: with a class that nothing mentions returns an empty list.
// (Bag class is a metaclass — nothing in the source tree spells
// `Bag class` as a single class-reference token, so this is a stable empty.)
SystemNavigation default referencesTo: Bag class
// => []

// BT-2195: Class-side method bodies participate. `SystemNavigation class
// >> #default` declares return type `-> SystemNavigation` which is a
// class reference, so the references to `SystemNavigation` must include
// at least one record whose `#class` is `SystemNavigation class`.
navRefs := SystemNavigation default referencesTo: SystemNavigation
// => _

(navRefs collect: [:r | r at: #class]) includes: SystemNavigation class
// => true

// Class object argument is required — passing a Symbol raises a useful error.
// This is the most common mistake since `sendersOf:` takes a Symbol.
[SystemNavigation default referencesTo: #Integer] on: Error do: [:e | #ok]
// => ok

// Passing a String also raises.
[SystemNavigation default referencesTo: "Integer"] on: Error do: [:e | #ok]
// => ok

// BT-2196: Extension method bodies registered via `register/5` (with source)
// are scanned by `referencesTo:` alongside class-body methods. Register an
// extension whose body mentions a uniquely-named class atom that does not
// resolve to a real class — we just need the FFI scan to find the textual
// reference in the source body. We use `Integer` (a real class) as the
// target, with an extension on `String` whose body references it.
extRefsFun := [:a :s | s]
// => _

extRefsSource := "asInt => Integer new"
// => _

Erlang beamtalk_extensions register: #String selector: #btTwoTwoOneSixSrcRefExt fun: extRefsFun owner: #test source: extRefsSource
// => _

extRefHits := SystemNavigation default referencesTo: Integer
// => _

(extRefHits collect: [:r | r at: #selector]) includes: #btTwoTwoOneSixSrcRefExt
// => true

Erlang ets delete: #beamtalk_extensions key: #(#String, #btTwoTwoOneSixSrcRefExt)
// => _

Erlang ets delete: #beamtalk_extension_sources key: #(#String, #btTwoTwoOneSixSrcRefExt)
// => _

// register/4 (no source) → invisible to referencesTo: scan.
extBareRefsFun := [:a :s | s]
// => _

Erlang beamtalk_extensions register: #String selector: #btTwoTwoOneSixBareRefExt fun: extBareRefsFun owner: #test
// => _

extBareRefHits := SystemNavigation default referencesTo: Integer
// => _

(extBareRefHits collect: [:r | r at: #selector]) includes: #btTwoTwoOneSixBareRefExt
// => false

Erlang ets delete: #beamtalk_extensions key: #(#String, #btTwoTwoOneSixBareRefExt)
// => _

// ===========================================================================
// SYSTEMNAVIGATION FIELDREADERSOF:IN: / FIELDWRITERSOF:IN: (BT-2208)
// ===========================================================================

// Load the stable field fixtures (parent + subclass). These give
// test-owned slots so assertions do not depend on live stdlib content.
:load tests/repl-protocol/fixtures/field_fixture.bt
// => _

:load tests/repl-protocol/fixtures/field_fixture_child.bt
// => _

// --- readers ---

// fieldReadersOf:in: finds every method that reads the named slot. The
// `tally` slot is read by `readTally` and by `bumpTally` (RHS of its
// assignment), so the result must be non-empty.
tallyReaders := SystemNavigation default fieldReadersOf: #tally in: FieldFixture
// => _

tallyReaders isEmpty
// => false

// Each record is a Dictionary with #class, #selector, #line keys — same shape
// as sendersOf: / referencesTo:.
tallyReaderRecord := tallyReaders first
// => _

tallyReaderRecord includesKey: #class
// => true

tallyReaderRecord includesKey: #selector
// => true

tallyReaderRecord includesKey: #line
// => true

// `readTally` reads the slot — collect the selectors and check membership.
tallyReaderSelectors := tallyReaders collect: [:r | r at: #selector]
// => _

tallyReaderSelectors includes: #readTally
// => true

// `bumpTally` reads the slot on the RHS of its assignment — also a reader.
tallyReaderSelectors includes: #bumpTally
// => true

// `clearTally` writes a literal (`self.tally := 0`) — it does NOT read the
// slot, so it must NOT appear among the readers.
tallyReaderSelectors includes: #clearTally
// => false

// Line numbers are 1-based positive integers.
(tallyReaders collect: [:r | r at: #line]) allSatisfy: [:n | n > 0]
// => true

// --- writers ---

// fieldWritersOf:in: finds every method that writes (assigns) the slot.
// `bumpTally` and `clearTally` both assign `self.tally`.
tallyWriters := SystemNavigation default fieldWritersOf: #tally in: FieldFixture
// => _

tallyWriterSelectors := tallyWriters collect: [:r | r at: #selector]
// => _

tallyWriterSelectors includes: #bumpTally
// => true

tallyWriterSelectors includes: #clearTally
// => true

// `readTally` only reads — it must NOT appear among the writers.
tallyWriterSelectors includes: #readTally
// => false

// --- read-modify-write appears in BOTH sets ---

// `bumpTally` (`self.tally := self.tally + 1`) reads AND writes the slot, so it
// shows up in the readers AND the writers result.
(tallyReaderSelectors includes: #bumpTally) and: [tallyWriterSelectors includes: #bumpTally]
// => true

// --- subclass inheriting the slot ---

// fieldReadersOf:/Writers: walk `aClass allSubclasses`. `FieldChild`
// inherits `tally` and defines `childBump` (`self.tally := self.tally + 2`),
// which reads and writes it. Scanning the PARENT must surface the child hit.
childReaders := SystemNavigation default fieldReadersOf: #tally in: FieldFixture
// => _

(childReaders collect: [:r | r at: #selector]) includes: #childBump
// => true

childWriters := SystemNavigation default fieldWritersOf: #tally in: FieldFixture
// => _

(childWriters collect: [:r | r at: #selector]) includes: #childBump
// => true

// The child hit names the subclass in #class — collect-then-includes to avoid
// in-block equality against a class reference.
((childReaders select: [:r | (r at: #selector) == #childBump])
  collect: [:r | r at: #class]) includes: FieldChild
// => true

// --- class-side field (classState:) via the metaclass walk ---

// `spawnCount` is a class-side field touched only by class-side methods. The
// metaclass walk (`cls class`) must find them; the #class is the metaclass
// object. `bumpSpawnCount` reads and writes it; `readSpawnCount` reads it.
spawnReaders := SystemNavigation default fieldReadersOf: #spawnCount in: FieldFixture
// => _

(spawnReaders collect: [:r | r at: #selector]) includes: #bumpSpawnCount
// => true

(spawnReaders collect: [:r | r at: #selector]) includes: #readSpawnCount
// => true

// Class-side hits report the metaclass OBJECT in #class.
((spawnReaders select: [:r | (r at: #selector) == #readSpawnCount])
  collect: [:r | r at: #class]) includes: FieldFixture class
// => true

spawnWriters := SystemNavigation default fieldWritersOf: #spawnCount in: FieldFixture
// => _

(spawnWriters collect: [:r | r at: #selector]) includes: #bumpSpawnCount
// => true

// `readSpawnCount` only reads — not a writer.
(spawnWriters collect: [:r | r at: #selector]) includes: #readSpawnCount
// => false

// --- declared-but-untouched slot returns [] ---

// `untouched` is a declared slot that no method reads or writes. Both queries
// return an empty list (NOT an error — it is a real slot).
SystemNavigation default fieldReadersOf: #untouched in: FieldFixture
// => []

SystemNavigation default fieldWritersOf: #untouched in: FieldFixture
// => []

// --- slot-name typo raises ---

// A name that is not a declared slot raises (typo guard) rather than silently
// returning [].
[SystemNavigation default fieldReadersOf: #notARealSlotXyzzy in: FieldFixture] on: Error do: [:e | #ok]
// => ok

[SystemNavigation default fieldWritersOf: #notARealSlotXyzzy in: FieldFixture] on: Error do: [:e | #ok]
// => ok

// --- Symbol slot name required ---

// Passing a non-Symbol slot name raises. Dispatch dynamically via perform: so
// the typed `:: Symbol` parameter does not reject the bad argument at compile
// time. (perform args must be a literal #(...) array, which can't hold a class
// reference, so the scope stays #FieldFixture; the slot-name guard runs first.)
[SystemNavigation default perform: #fieldReadersOf:in: withArguments: #(42, #FieldFixture)] on: Error do: [:e | #ok]
// => ok

// ===========================================================================
// SYSTEMNAVIGATION METHODSMATCHING: — source-text grep (BT-2205)
// ===========================================================================

// methodsMatching: returns a non-empty list when the pattern hits a loaded
// method body. SysnavFixture >> #btIfTrueBodyMarker sends `ifTrue:` in its
// body (see fixture), so the search must produce at least one hit. Using a
// fixture-controlled method avoids depending on stdlib bodies (BT-2220).
ifTrueMethods := SystemNavigation default methodsMatching: (Regex from: "ifTrue:") unwrap
// => _

ifTrueMethods isEmpty
// => false

// Each record is a Dictionary with #class and #selector keys (no #line —
// methodsMatching: returns one record per matching method, not per
// occurrence).
ifTrueMethodRecord := ifTrueMethods first
// => _

ifTrueMethodRecord includesKey: #class
// => true

ifTrueMethodRecord includesKey: #selector
// => true

// SysnavFixture >> #btNegatedBodyMarker contains `self negated` in its body
// (see fixture). Confirm the record appears — this is fixture-controlled and
// stable against stdlib refactoring (BT-2220).
negatedMatches := SystemNavigation default methodsMatching: (Regex from: "self negated") unwrap
// => _

(negatedMatches collect: [:r | r at: #class]) includes: SysnavFixture
// => true

(negatedMatches collect: [:r | r at: #selector]) includes: #btNegatedBodyMarker
// => true

// methodsMatching: with a pattern that nobody's source contains returns an
// empty list. The pattern is split across two literals so the script file
// itself doesn't trigger a self-match.
absent := "xyzzyAbsentNeed" ++ "leZZ1n0Wh3re"
// => _

SystemNavigation default methodsMatching: (Regex from: absent) unwrap
// => []

// Regex argument is required — passing a String (raw pattern) raises a
// useful error, mirroring sendersOf:'s Symbol-only contract.
[SystemNavigation default methodsMatching: "ifTrue:"] on: Error do: [:e | #ok]
// => ok

// BT-2195: Class-side method bodies participate. `SystemNavigation class
// >> #default` body contains the literal `self new`, so a regex over
// that literal must include a record whose `#class` is `SystemNavigation
// class`.
newSelfMatches := SystemNavigation default methodsMatching: (Regex from: "self new") unwrap
// => _

(newSelfMatches collect: [:r | r at: #class]) includes: SystemNavigation class
// => true

// BT-2196: Extension methods registered via `register/5` (with source)
// also participate in `methodsMatching:`. Register an extension whose
// body contains a unique marker, then assert the pattern surfaces it.
extMatchFun := [:a :s | s]
// => _

extMatchSource := "xyzzy => 42 // bt-two-two-one-six-method-marker"
// => _

Erlang beamtalk_extensions register: #Integer selector: #btTwoTwoOneSixMatchExt fun: extMatchFun owner: #test source: extMatchSource
// => _

extMatchHits := SystemNavigation default methodsMatching: (Regex from: "bt-two-two-one-six-method-marker") unwrap
// => _

(extMatchHits collect: [:r | r at: #selector]) includes: #btTwoTwoOneSixMatchExt
// => true

Erlang ets delete: #beamtalk_extensions key: #(#Integer, #btTwoTwoOneSixMatchExt)
// => _

Erlang ets delete: #beamtalk_extension_sources key: #(#Integer, #btTwoTwoOneSixMatchExt)
// => _

// ===========================================================================
// SYSTEMNAVIGATION SELECTORSMATCHING: — fuzzy selector search (BT-2204)
// ===========================================================================

// Substring match for a fixture-controlled selector. SysnavFixture defines
// `#btAppendMarker` (see fixture), so a search for "append" must produce at
// least this hit. Using a fixture-controlled selector avoids depending on
// stdlib having selectors that contain "append" (BT-2220).
appendHits := SystemNavigation default selectorsMatching: "append"
// => _

appendHits isEmpty
// => false

// Every hit's printable name actually contains the substring "append"
// (case-insensitive, so a lowercase test of each hit hits the lowercase needle).
appendHits allSatisfy: [:s | s asString lowercase includesSubstring: "append"]
// => true

// Case-insensitive: an uppercase pattern returns the same hits as lowercase.
upperHits := SystemNavigation default selectorsMatching: "APPEND"
// => _

upperHits size == appendHits size
// => true

// Result is sorted alphabetically — sorting again does not change anything.
appendHits asString == (appendHits sort) asString
// => true

// Result is deduplicated — `unique` does not shrink the list further.
appendHits size == (appendHits unique) size
// => true

// `#=` is defined on many classes but appears once in the deduped result.
equalsHits := SystemNavigation default selectorsMatching: "="
// => _

equalsHits size == (equalsHits unique) size
// => true

// Counter (loaded above) locally defines `increment` — that selector shows up
// in a substring search for "incr".
(SystemNavigation default selectorsMatching: "incr") includes: #increment
// => true

// Class-side selectors participate. `default` is a class-side method on
// SystemNavigation, so it appears in a search for "default".
(SystemNavigation default selectorsMatching: "default") includes: #default
// => true

// Extension methods (ADR 0066) participate. Register a uniquely-named
// extension and verify the selector shows up; clean up the ETS entry after.
extFun := [:a :s | s]
// => _

Erlang beamtalk_extensions register: #Integer selector: #btTwoTwoFourExtMarker fun: extFun owner: #test
// => _

(SystemNavigation default selectorsMatching: "btTwoTwoFourExtMarker") includes: #btTwoTwoFourExtMarker
// => true

Erlang ets delete: #beamtalk_extensions key: #(#Integer, #btTwoTwoFourExtMarker)
// => _

// No-match returns an empty list.
SystemNavigation default selectorsMatching: "ZzZxYwQpPpNoSuchSelectorXyzzy"
// => []

// Empty pattern is rejected with a typed error.
[SystemNavigation default selectorsMatching: ""] on: Error do: [:e | #ok]
// => ok

// Non-String argument is rejected with a typed error.
[SystemNavigation default selectorsMatching: #notAString] on: Error do: [:e | #ok]
// => ok

// ===========================================================================
// SYSTEMNAVIGATION UNIMPLEMENTEDSELECTORS — typo-finder lint (BT-2206)
// ===========================================================================

// Load fixtures: a deliberate typo, a DNU dispatcher, and a perform: caller.
:load tests/repl-protocol/fixtures/typo_sender.bt
// => _

:load tests/repl-protocol/fixtures/dnu_dispatcher.bt
// => _

:load tests/repl-protocol/fixtures/perform_sender.bt
// => _

// unimplementedSelectors returns a List of records (selector + sites).
unimpl := SystemNavigation default unimplementedSelectors
// => _

// The deliberate typo `printOnStream:` (sent in TypoSender >> describe:, defined
// nowhere) shows up. Collect the flagged selectors and check membership rather
// than equality against the whole list (which carries any test-session noise).
unimplSelectors := unimpl collect: [:r | r at: #selector]
// => _

unimplSelectors includes: #printOnStream:
// => true

// Locate the printOnStream: record and verify its shape: #selector + #sites.
typoRecord := unimpl detect: [:r | (r at: #selector) == #printOnStream:]
// => _

typoRecord includesKey: #selector
// => true

typoRecord includesKey: #sites
// => true

// The site list is non-empty and each site has #class / #selector / #line.
typoSites := typoRecord at: #sites
// => _

typoSites isEmpty
// => false

typoSite := typoSites first
// => _

typoSite includesKey: #class
// => true

typoSite includesKey: #selector
// => true

typoSite includesKey: #line
// => true

// The site points at the right class and method — collect-then-includes to
// avoid in-block equality against a class reference.
(typoSites collect: [:s | s at: #class]) includes: TypoSender
// => true

(typoSites collect: [:s | s at: #selector]) includes: #describe:
// => true

// Line numbers are 1-based positive integers (relative to the method source).
(typoSites collect: [:s | s at: #line]) allSatisfy: [:n | n > 0]
// => true

// A class that defines `doesNotUnderstand:args:` and self-sends an undefined
// selector does NOT pollute results — the coarse DNU heuristic suppresses
// self/super sends in such a class.
unimplSelectors includes: #dnuOnlyHandledSelectorXyzzy
// => false

// `self perform: #performOnlyXyzzy` does NOT get `performOnlyXyzzy` flagged —
// the dynamic selector is a Symbol literal, never an AST send.
unimplSelectors includes: #performOnlyXyzzy
// => false

// And `perform:` itself (defined on Object) is never flagged.
unimplSelectors includes: #perform:
// => false

// ===========================================================================
// SYSTEMNAVIGATION UNUSEDSELECTORS — dead-method candidates (BT-2207)
// ===========================================================================

// Load fixtures: a class with a used + an unused method, a runtime-called `hash`
// override, a TestCase subclass, and a perform:-only caller.
:load tests/repl-protocol/fixtures/unused_demo.bt
// => _

:load tests/repl-protocol/fixtures/unused_runtime_called.bt
// => _

:load tests/repl-protocol/fixtures/unused_testcase.bt
// => _

:load tests/repl-protocol/fixtures/unused_perform.bt
// => _

// unusedSelectors returns a List of #{#class, #selector} records.
unused := SystemNavigation default unusedSelectors
// => _

// The stdlib has many public-but-internally-unsent selectors, so the live
// result is expected to be non-empty (do NOT assert it is empty).
unused isEmpty
// => false

// Collect the flagged selectors once; membership checks avoid in-block equality.
unusedSelectors := unused collect: [:r | r at: #selector]
// => _

// `neverCalledHelper` is sent nowhere — it shows up as a dead-method candidate.
unusedSelectors includes: #neverCalledHelper
// => true

// `usedHelper` IS sent (by UnusedDemo >> caller), so it does NOT show up.
unusedSelectors includes: #usedHelper
// => false

// Locate the neverCalledHelper record and verify its shape: #class + #selector.
unusedRecord := unused detect: [:r | (r at: #selector) == #neverCalledHelper]
// => _

unusedRecord includesKey: #class
// => true

unusedRecord includesKey: #selector
// => true

// The flagged record's #class is the defining class — collect-then-includes to
// avoid in-block equality against a class reference (mirrors the BT-2206 section).
((unused select: [:r | (r at: #selector) == #neverCalledHelper])
  collect: [:r | r at: #class]) includes: UnusedDemo
// => true

// A `hash` override is NOT flagged even though nothing visibly sends it —
// runtime-called-override exclusion (it is in runtimeCalledSelectors). `hash` is
// chosen deliberately: it is sent NOWHERE in stdlib source, so the sent-set does
// not cover it, and the fixture's body is real Beamtalk, so the primitive
// heuristic does not cover it — the runtimeCalledSelectors exclusion is the only
// thing keeping it out, so this genuinely exercises that exclusion.
unusedSelectors includes: #hash
// => false

// The override's body is real (non-primitive) Beamtalk, confirming the exclusion
// above is doing the work rather than the primitive heuristic.
SystemNavigation default isPrimitiveMethod: #hash in: UnusedRuntimeCalled
// => false

// A TestCase subclass's `testSomething` / `setUp` / `tearDown` are NOT flagged —
// the runner invokes them reflectively (TestCase test-runner exclusion). Scope
// each check to the fixture class so an unrelated future class defining one of
// these names cannot perturb the assertion.
((unused select: [:r | (r at: #selector) == #testSomething])
  collect: [:r | r at: #class]) includes: UnusedTestCaseFixture
// => false

((unused select: [:r | (r at: #selector) == #setUp])
  collect: [:r | r at: #class]) includes: UnusedTestCaseFixture
// => false

((unused select: [:r | (r at: #selector) == #tearDown])
  collect: [:r | r at: #class]) includes: UnusedTestCaseFixture
// => false

// A `@primitive` / `@intrinsic`-bodied method is NOT flagged. `fieldAt:put:`
// (`@intrinsic fieldAtPut` on Object) is sent nowhere in source, so without the
// primitive heuristic it would be flagged; the exclusion keeps it out.
unusedSelectors includes: #fieldAt:put:
// => false

// The primitive heuristic helper agrees: a stdlib intrinsic reads as primitive.
SystemNavigation default isPrimitiveMethod: #hash in: Object
// => true

// ...while an ordinary stdlib method does not.
SystemNavigation default isPrimitiveMethod: #displayString in: Object
// => false

// Documented limitation: a method reached ONLY via `self perform: #dynamicOnly`
// IS flagged — the dynamic selector is a Symbol literal, never an AST send, so
// the scan cannot see the use. This encodes the known false positive.
unusedSelectors includes: #dynamicOnly
// => true

// `caller` (UnusedDemo) sends `usedHelper`, a real source send, so `caller` is
// itself unused (sent by nobody) and SHOULD appear — confirming the scan flags
// ordinary unsent methods, not just contrived ones.
unusedSelectors includes: #caller
// => true

// ===========================================================================
// SYSTEMNAVIGATION FFISITESFOR: — Erlang FFI call-site finder (BT-2211)
// ===========================================================================

// Load the stable FFI fixture. It defines test-owned methods that invoke real
// Erlang functions through the `Erlang` bridge, so assertions do not depend on
// live stdlib bodies.
:load tests/repl-protocol/fixtures/ffi_fixture.bt
// => _

// --- happy path: a real FFI call shows up with {#class, #selector, #line} ---

// ffiSitesFor: "lists:reverse" finds every method that calls lists:reverse
// through the FFI bridge. FfiFixture >> #revInstance: and the class-side
// #revClassSide: both call it, so the result must be non-empty.
revSites := SystemNavigation default ffiSitesFor: "lists:reverse"
// => _

revSites isEmpty
// => false

// Each record is a Dictionary with #class, #selector, #line keys — same shape
// as sendersOf: / referencesTo: / fieldReadersOf:in:.
revSiteRecord := revSites first
// => _

revSiteRecord includesKey: #class
// => true

revSiteRecord includesKey: #selector
// => true

revSiteRecord includesKey: #line
// => true

// `revInstance:` calls lists:reverse — collect the selectors and check membership.
revSiteSelectors := revSites collect: [:r | r at: #selector]
// => _

revSiteSelectors includes: #revInstance:
// => true

// `plainSend:` sends a plain Beamtalk `reverse` (not an FFI call) — it must NOT
// appear among the FFI sites.
revSiteSelectors includes: #plainSend:
// => false

// `seqInstance` calls lists:seq, a DIFFERENT function — not a lists:reverse site.
revSiteSelectors includes: #seqInstance
// => false

// Line numbers are 1-based positive integers.
(revSites collect: [:r | r at: #line]) allSatisfy: [:n | n > 0]
// => true

// --- class-side FFI sites participate (metaclass walk) ---

// `revClassSide:` is a class-side method calling lists:reverse. The metaclass
// walk (`cls class`) must find it; the #class is the metaclass object.
revSiteSelectors includes: #revClassSide:
// => true

((revSites select: [:r | (r at: #selector) == #revClassSide:])
  collect: [:r | r at: #class]) includes: FfiFixture class
// => true

// --- arity-qualified spec narrows the match ---

// lists:reverse is called with arity 1 in the fixture. The arity-qualified spec
// "lists:reverse/1" still matches `revInstance:`...
revArity1 := SystemNavigation default ffiSitesFor: "lists:reverse/1"
// => _

(revArity1 collect: [:r | r at: #selector]) includes: #revInstance:
// => true

// ...while "lists:reverse/2" matches nothing (no arity-2 reverse call exists).
SystemNavigation default ffiSitesFor: "lists:reverse/2"
// => []

// --- different function is matched independently ---

// "lists:seq" finds `seqInstance` (a lists:seq/2 call) but NOT the reverse sites.
seqSites := SystemNavigation default ffiSitesFor: "lists:seq"
// => _

(seqSites collect: [:r | r at: #selector]) includes: #seqInstance
// => true

(seqSites collect: [:r | r at: #selector]) includes: #revInstance:
// => false

// The arity-qualified "lists:seq/2" matches (seq: 1 to: 10 is arity 2).
seqArity2 := SystemNavigation default ffiSitesFor: "lists:seq/2"
// => _

(seqArity2 collect: [:r | r at: #selector]) includes: #seqInstance
// => true

// --- extension-method FFI sites participate (ADR 0066 / BT-2196) ---

// Register an extension whose body makes a lists:reverse FFI call, then assert
// ffiSitesFor: finds it. Clean up both ETS tables afterward.
extFfiFun := [:a :s | s]
// => _

extFfiSource := "describe: xs => (Erlang lists) reverse: xs"
// => _

Erlang beamtalk_extensions register: #Integer selector: #btTwoTwoOneOneFfiExt fun: extFfiFun owner: #test source: extFfiSource
// => _

extFfiHits := SystemNavigation default ffiSitesFor: "lists:reverse"
// => _

(extFfiHits collect: [:r | r at: #selector]) includes: #btTwoTwoOneOneFfiExt
// => true

Erlang ets delete: #beamtalk_extensions key: #(#Integer, #btTwoTwoOneOneFfiExt)
// => _

Erlang ets delete: #beamtalk_extension_sources key: #(#Integer, #btTwoTwoOneOneFfiExt)
// => _

// --- no-match returns [] ---

// A well-formed spec for a function that nobody calls returns an empty list
// (NOT an error).
SystemNavigation default ffiSitesFor: "lists:noSuchFunctionXyzzy"
// => []

// --- malformed spec raises ---

// A spec that does not match the module:function[/arity] shape raises (kind
// #user_error), so a typo surfaces rather than silently returning [].
[SystemNavigation default ffiSitesFor: "nocolon"] on: Error do: [:e | #ok]
// => ok

[SystemNavigation default ffiSitesFor: "a:b:c"] on: Error do: [:e | #ok]
// => ok

[SystemNavigation default ffiSitesFor: "lists:reverse/x"] on: Error do: [:e | #ok]
// => ok
