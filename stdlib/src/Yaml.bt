/// Yaml — YAML parsing and generation.
///
/// Provides class methods for parsing YAML strings into Beamtalk values
/// and generating YAML strings from Beamtalk values. Uses `yamerl` as the
/// underlying YAML library (pure Erlang, no NIFs).
///
/// ## Type Mapping
///
/// | YAML          | Beamtalk     |
/// |---------------|--------------|
/// | mapping       | Dictionary (keys typed per scalar) |
/// | sequence      | List         |
/// | string        | String       |
/// | integer       | Integer      |
/// | float         | Float        |
/// | true/false    | Boolean      |
/// | null/~        | nil          |
///
/// ## Examples
/// ```beamtalk
/// (Yaml parse: "answer: 42") unwrap         // => _
/// (Yaml parse: "- 1\n- 2\n- 3") unwrap     // => _
/// Yaml generate: #{"name" => "Ada"}
/// // => _
/// (Yaml parseFile: "/etc/myapp.yaml") unwrap
/// // => _
/// ```
sealed Object subclass: Yaml

  /// Parse a YAML string into a Beamtalk value (class method).
  ///
  /// YAML mappings become Dictionaries whose key types follow the YAML scalar
  /// type (string keys → Strings, integer keys → Integers), sequences become
  /// Lists, strings become Strings, integers become Integers, floats become
  /// Floats, booleans stay as true/false, null/~ becomes nil.
  ///
  /// For multi-document YAML, only the first document is returned.
  /// Use `parseAll:` to get all documents.
  ///
  /// ## Examples
  /// ```beamtalk
  /// (Yaml parse: "42") unwrap              // => 42
  /// (Yaml parse: "- 1\n- 2\n- 3") unwrap  // => [1,2,3]
  /// (Yaml parse: "null") unwrap            // => nil
  /// ```
  class sealed parse: yamlString :: String -> Result =>
    (Erlang beamtalk_yaml) parse: yamlString

  /// Parse a multi-document YAML string into a List of values (class method).
  ///
  /// Returns a List containing one Beamtalk value per YAML document
  /// (documents are separated by ---).
  ///
  /// ## Examples
  /// ```beamtalk
  /// (Yaml parseAll: "42\n---\n43") unwrap   // => _
  /// ```
  class sealed parseAll: yamlString :: String -> Result =>
    (Erlang beamtalk_yaml) parseAll: yamlString

  /// Generate a YAML string from a Beamtalk value (class method).
  ///
  /// Produces valid YAML 1.2 in flow style. Dictionaries become YAML
  /// mappings, Lists become sequences, Strings become YAML strings,
  /// Integer/Float become numbers, true/false become YAML booleans,
  /// nil becomes null.
  ///
  /// ## Examples
  /// ```beamtalk
  /// Yaml generate: #(1, 2, 3)              // => _
  /// Yaml generate: nil                     // => _
  /// Yaml generate: 42                      // => _
  /// ```
  class sealed generate: value :: Object -> String =>
    (Erlang beamtalk_yaml) generate: value

  /// Parse a YAML file into a Beamtalk value (class method).
  ///
  /// Reads the file at the given path and parses it as YAML.
  /// Returns the first document from the file.
  ///
  /// ## Examples
  /// ```beamtalk
  /// (Yaml parseFile: "/etc/myapp.yaml") unwrap   // => _
  /// ```
  class sealed parseFile: path :: String -> Result =>
    (Erlang beamtalk_yaml) parseFile: path
