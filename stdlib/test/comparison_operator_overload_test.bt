// BT-2710: Phase 2 — comparison operators (`< > <= >=`) are dispatchable as real
// messages, so a user value-type can overload them and have `aMoney < bMoney`
// dispatch to `Money>><` (receiver decides). Unlike a bare `erlang:'<'` — which
// defines a total order over *every* term and would silently term-order an
// object — the codegen guard discriminates on "is this a Beamtalk object?", so
// a type with no comparison operator falls through to a `does_not_understand`
// DNU rather than a silently-wrong term-order result.
//
// The `Money` and `Widget` value-types live in `fixtures/` (one class per file).

TestCase subclass: ComparisonOperatorOverloadTest

  /// `aMoney < bMoney` dispatches to `Money>><`.
  testUserTypeLessThanDispatches =>
    a := (Money new) withCents: 150
    b := (Money new) withCents: 250
    self assert: (a < b)
    self deny: (b < a)

  /// `aMoney > bMoney` dispatches to `Money>>>`.
  testUserTypeGreaterThanDispatches =>
    a := (Money new) withCents: 500
    b := (Money new) withCents: 175
    self assert: (a > b)
    self deny: (b > a)

  /// `aMoney <= bMoney` dispatches to `Money>><=` (true at the boundary).
  testUserTypeLessOrEqualDispatches =>
    a := (Money new) withCents: 200
    b := (Money new) withCents: 200
    self assert: (a <= b)
    self assert: (a >= b)

  /// `aMoney >= bMoney` dispatches to `Money>>>=`.
  testUserTypeGreaterOrEqualDispatches =>
    a := (Money new) withCents: 300
    b := (Money new) withCents: 150
    self assert: (a >= b)
    self deny: (b >= a)

  /// Numeric comparison still works (the bare-BIF fast path is unchanged).
  testNumericComparisonUnchanged =>
    self assert: (2 < 3)
    self assert: (10 > 4)
    self assert: (5 <= 5)
    self assert: (7 >= 7)

  /// Character and string comparison still take the bare comparison BIF.
  testCharAndStringComparisonUnchanged =>
    self assert: ($a < $b)
    self assert: ("abc" < "abd")

  /// BT-2710 follow-up: comparing on an OBJECT-typed field dispatches to the
  /// field type's `<`, not Erlang term-order. `DescendingPair>><` delegates to
  /// `self.key < other key` where `key :: DescendingInt` — a type whose order is
  /// the REVERSE of its underlying integer. So the pair with the larger inner
  /// `n` is "less than", the opposite of what term-ordering the inner tagged map
  /// would yield. This assertion fails if the field stays on the bare BIF.
  testObjectTypedFieldComparisonDispatches =>
    small := (DescendingPair new) withKey: ((DescendingInt new) withN: 2)
    big := (DescendingPair new) withKey: ((DescendingInt new) withN: 8)
    self assert: (big < small)
    self deny: (small < big)

  /// `<` on a type with no comparison operator raises a DNU, not a silently
  /// wrong term-order result. `w` is statically a `Widget` (which defines no
  /// `<`), so the checker also flags this at compile time — `@expect dnu`
  /// acknowledges that hint while the assertion verifies the runtime behaviour.
  testNoOperatorRaisesDoesNotUnderstand =>
    w := (Widget new) withSize: 5
    @expect dnu
    self should: [w < 1] raise: #does_not_understand
