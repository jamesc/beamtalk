// BT-1408: Regression test — Value subclass with 20+ long camelCase field names.
// Previously failed with core_scan_error because the auto-generated keyword
// constructor atom exceeded Erlang's 255-char atom limit.

Value subclass: ValueManyFields
  state: codexInputTokens = 0
  state: codexOutputTokens = 0
  state: codexModelName = ""
  state: codexCachedTokens = 0
  state: codexReasoning = ""
  state: codexReasoningEffort = ""
  state: codexMaxOutputTokens = 0
  state: codexSystemFingerprint = ""
  state: codexServiceTier = ""
  state: operationTokens = 0
  state: operationCost = 0
  state: operationDuration = 0
  state: apiCallCount = 0
  state: errorCount = 0
  state: retryCount = 0
  state: totalLatency = 0
  state: averageLatency = 0
  state: peakMemoryUsage = 0
  state: networkBandwidth = 0
  state: concurrentRequests = 0
