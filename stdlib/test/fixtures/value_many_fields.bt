// BT-1408: Regression test — Value subclass with 20+ long camelCase field names.
// Previously failed with core_scan_error because the auto-generated keyword
// constructor atom exceeded Erlang's 255-char atom limit.

Value subclass: ValueManyFields
  field: codexInputTokens = 0
  field: codexOutputTokens = 0
  field: codexModelName = ""
  field: codexCachedTokens = 0
  field: codexReasoning = ""
  field: codexReasoningEffort = ""
  field: codexMaxOutputTokens = 0
  field: codexSystemFingerprint = ""
  field: codexServiceTier = ""
  field: operationTokens = 0
  field: operationCost = 0
  field: operationDuration = 0
  field: apiCallCount = 0
  field: errorCount = 0
  field: retryCount = 0
  field: totalLatency = 0
  field: averageLatency = 0
  field: peakMemoryUsage = 0
  field: networkBandwidth = 0
  field: concurrentRequests = 0
