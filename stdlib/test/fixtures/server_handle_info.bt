// BT-1457: Server subclass fixture for handleInfo: codegen testing

Server subclass: HandleInfoCounter
  state: count = 0
  state: lastMsg = nil

  handleInfo: msg =>
    msg == #tick ifTrue: [
      self.count := self.count + 1
    ] ifFalse: [self.lastMsg := msg]

  getCount => self.count

  getLastMsg => self.lastMsg
