// SlowActor — Test fixture that sleeps before responding.
// Used by TimeoutProxyTest to verify timeout behavior.

Actor subclass: SlowActor
  state: value = 42

  // Returns value after sleeping for the given milliseconds
  slowGet: ms =>
    Timer sleep: ms
    self.value

  // Fast getter for comparison
  getValue => self.value
