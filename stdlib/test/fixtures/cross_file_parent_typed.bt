// BT-1976 fixture — cross-file parent with a typed-no-default field that it
// does NOT set in its own `initialize`. A child in a separate file is
// expected to set the inherited field before post-initialize validation runs.

typed Actor subclass: CrossFileParentTyped
  state: token :: String

  getToken -> String => self.token
