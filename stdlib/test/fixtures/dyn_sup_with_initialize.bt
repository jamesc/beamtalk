// BT-1542: DynamicSupervisor with initialize: hook that pre-populates children.
// initialize: calls startChild — this verifies the hook runs and the supervisor
// is responsive during the callback.

DynamicSupervisor(Counter) subclass: DynSupWithInitialize

  class childClass => Counter

  class initialize: sup =>
    sup startChild unwrap
    sup startChild unwrap
