// BT-1475: Fixture for testing self-send inside Timer blocks.
// The initialize method schedules a Timer that fires a self-cast,
// which should route through the actor mailbox — not call safe_dispatch
// on a stale state snapshot.

Actor subclass: TimerSelfSendActor
  state: count = 0

  initialize => Timer after: 10 do: [self bump!]

  bump => self.count := self.count + 1

  // Schedule a self-cast via a deferred Timer callback.
  // The block [self bump!] captures self and executes in the Timer process.
  deferBump => Timer after: 10 do: [self bump!]

  getCount => self.count
