// BT-598: Test fixture for local variable mutation in actor method blocks
// Actor with methods that mutate local variables in various control flow constructs

Actor subclass: LocalMutationActor
  state: log = 0
  state: step = 1

  getLog => self.log

  // Local mutation in do: (lists:foldl path)
  sumWithDo: items =>
    total := 0
    items do: [:item | total := total + item]
    total

  // Local mutation in inject:into:
  sumWithInject: items =>
    count := 0
    result := items
      inject: 0
      into: [:acc :item |
        count := count + 1
        acc + item
      ]
    #{#result => result, #count => count}

  // Local mutation in timesRepeat:
  countToN: n =>
    counter := 0
    n timesRepeat: [counter := counter + 1]
    counter

  // Local mutation in to:do:
  sumRange: n =>
    total := 0
    1 to: n do: [:i | total := total + i]
    total

  // Local mutation in whileTrue:
  countDownFrom: n =>
    counter := n
    steps := 0
    [counter > 0]
      whileTrue: [
        counter := counter - 1
        steps := steps + 1
      ]
    steps

  // Local mutation in whileFalse:
  countUpWithWhileFalseFrom: n =>
    counter := 0
    [counter >= n] whileFalse: [counter := counter + 1]
    counter

  // Local mutation in to:by:do:
  sumEvens: n =>
    total := 0
    2
      to: n
      by: 2
      do: [:i | total := total + i]
    total

  // Mixed local + field mutation
  processWithTracking: items =>
    localCount := 0
    items
      do: [:item |
        localCount := localCount + 1
        self.log := self.log + item
      ]
    #{#localCount => localCount, #log => self.log}

  // BT-1224: Block-local variable (not captured from outer scope) assigned and read
  // within the same block iteration. Previously caused {unbound_var,'Doubled',{dispatch,4}}
  // because `compute_threaded_locals_for_loop` used `local_reads` instead of `captured_reads`,
  // incorrectly packing block-local vars into the pre-loop StateAcc map.
  doubleAndSum: items =>
    total := 0
    items
      do: [:item |
        doubled := item * 2
        total := total + doubled
      ]
    total

  // BT-1276: select: with local mutation (tuple-acc path)
  selectPositiveWithCount: items =>
    count := 0
    result := items
      select: [:item |
        count := count + 1
        item > 0
      ]
    #{#result => result, #count => count}

  // BT-1276: reject: with local mutation (tuple-acc path)
  rejectNegativeWithCount: items =>
    count := 0
    result := items
      reject: [:item |
        count := count + 1
        item < 0
      ]
    #{#result => result, #count => count}

  // BT-1326: hybrid direct-params + State threading
  // Counted loop with BOTH local var mutation AND field mutation.
  sumAndCountToN: n =>
    sum := 0
    1
      to: n
      do: [:i |
        sum := sum + i
        self.log := self.log + 1
      ]
    #{#sum => sum, #log => self.log}

  sumAndCountTimesRepeat: n =>
    sum := 0
    n
      timesRepeat: [
        sum := sum + 1
        self.log := self.log + 1
      ]
    #{#sum => sum, #log => self.log}

  // BT-1326: Read-only field optimization — self.step is read but never written
  // in the loop body, so it is pre-extracted before the letrec and passed as a
  // direct fun parameter (no per-iteration maps:get for step).
  sumWithStep: n =>
    sum := 0
    1
      to: n
      do: [:i |
        sum := sum + self.step
        self.log := self.log + 1
      ]
    #{#sum => sum, #log => self.log}

  // BT-1329: Nested list op (do:) inside counted loop with cross-scope mutation.
  // The do: block captures and mutates `count` from the outer to:do: scope.
  // Direct-params loop should use expanded tuple for the inner list op.
  countItemsInRangeWithDo: items times: n =>
    count := 0
    1 to: n do: [:i | items do: [:x | count := count + 1]]
    count

  // BT-1329: Nested inject:into: inside counted loop — outer var assigned from inject result.
  sumItemsNTimes: items times: n =>
    total := 0
    1 to: n do: [:i | total := items inject: total into: [:acc :x | acc + x]]
    total

  // BT-1329: Nested collect: inside counted loop with cross-scope mutation.
  collectAndCountNTimes: items times: n =>
    count := 0
    result := #()
    1
      to: n
      do: [:i |
        result := items
          collect: [:x |
            count := count + 1
            x * i
          ]
      ]
    #{#result => result, #count => count}
