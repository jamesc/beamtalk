// BT-1937: Fixture for class var mutations from sub-expression class method
// self-sends. Each method here mutates `counter` from a class method that
// is invoked as a sub-expression of another message send (argument position,
// receiver position, etc.). Without the BT-1937 fix, the mutation produced
// by the inner self-send is silently dropped because its `ClassVarsN`
// binding is scoped inside the closed sub-expression.

Object subclass: ClassVarSubExpr
  classState: counter = 0

  // Mutates the class var and returns the new value.
  class tick =>
    self.counter := self.counter + 1
    self.counter

  // Identity-style class method used as a wrapper around its argument so we
  // can test that the inner mutation propagates THROUGH the outer call.
  class describe: x :: Integer -> String => x printString

  // (BT-1937 root case) Class method self-send used as the keyword argument
  // of another class method self-send.
  class tickAsArgument => self describe: (self tick)

  // Class method self-send used as the receiver of another message send.
  // After this method runs once, counter must be 1.
  class tickAsReceiver => (self tick) printString

  // Two sub-expression self-sends in the same outer call. Each one mutates
  // counter, so a single call should leave counter at 2.
  class tickPair => self combine: (self tick) with: (self tick)

  // Helper used by tickPair: returns a string built from both inputs.
  class combine: a with: b :: Integer -> String =>
    a printString ++ "," ++ b printString

  // Class method self-send as operand of a binary operator. Counter must
  // increment AND the binary op must produce valid Core Erlang.
  class tickPlusOne => (self tick) + 1

  // Class method self-send as element of a list literal. Each element ticks
  // the counter so a single call must leave counter at 3.
  class tickList => #(self tick, self tick, self tick)

  // Class method self-send as the right-hand side of `++` (concat).
  class tickConcat => "n=" ++ (self tick) printString

  // Evaluation-order test: read self.counter as the first argument and run
  // a self-send that mutates counter as the second argument. The read must
  // observe the PRE-mutation value (left-to-right semantics), and the
  // counter must end mutated by the second argument.
  class readThenTick => self combine: self.counter with: (self tick)

  // Inverse: tick first, then read. The read must observe the POST-mutation
  // value, and the counter must end mutated by the first argument.
  class tickThenRead => self combine: (self tick) with: self.counter

  class currentCounter => self.counter

  class resetCounter => self.counter := 0

  // BT-1942: `(self tick) class` — class method self-send as receiver of a
  // ProtoObject intrinsic. Before the fix this produced malformed Core Erlang
  // because `class` inlined the receiver inside a `let _Obj = <open> in ...`.
  class tickClass => (self tick) class

  // BT-1942: `(self tick) isNil` / `notNil` — nil protocol intrinsics.
  class tickIsNil => (self tick) isNil

  class tickNotNil => (self tick) notNil

  // BT-1942: `(self tick) ifNil: [...]` / `ifNotNil: [...]` — nil conditional
  // intrinsics. Both should compile AND tick the counter once.
  class tickIfNil => (self tick) ifNil: ["was nil"]

  class tickIfNotNil => (self tick) ifNotNil: [:v | v printString]

  // BT-1942: `(self tick) ifNil:ifNotNil:` / `ifNotNil:ifNil:` — two-way nil
  // conditionals.
  class tickIfNilIfNotNil =>
    (self tick) ifNil: ["nil"] ifNotNil: [:v | v printString]

  class tickIfNotNilIfNil =>
    (self tick) ifNotNil: [:v | v printString] ifNil: ["nil"]

  // BT-1942: `(self tick) yourself` / `hash` — object identity intrinsics.
  class tickYourself => (self tick) yourself

  class tickHash => (self tick) hash

  // BT-1942: `(self tick) respondsTo: #foo` — object reflection.
  class tickRespondsTo => (self tick) respondsTo: #printString

  // BT-1942: `someBlock value: (self tick)` — value keyword guard on a
  // non-block receiver (identity block that returns its argument).
  class tickAsBlockValueArg =>
    identity := [:x | x printString]
    identity value: (self tick)

  // BT-1942: `Logger info: (self tick)` — logger intrinsic. Logger returns
  // nil but the class var must still be mutated.
  class tickAsLoggerArg =>
    Logger info: (self tick) printString
    self.counter

  // BT-1942: `(self tick) > 0 ifTrue: [...]` inside a loop body —
  // exercises `generate_if_true_with_mutations` receiver path. Running in
  // a `to:do:` loop sets `in_loop_body`, and the local write inside the
  // `ifTrue:` block triggers the mutation-threaded conditional codegen.
  // The binary op receiver `(self tick) > 0` carries the open let-chain
  // from BT-1937 through to the conditional, which must split the chain
  // into a preamble so ClassVarsN stays in scope for the case binding.
  class tickInLoopConditional =>
    hits := 0
    1 to: 1 do: [:i | (self tick) > 0 ifTrue: [hits := hits + 1]]
    hits

  // BT-1942: Explicit `^` return with an open-scope receiver. Before the
  // fix, `generate_class_method_return` used `expression_doc(value)` which
  // did not handle the open let-chain, producing a malformed
  // `let _Ret = let _CMR = ... in ... in  in ` (double `in`).
  class tickReturnClass => ^(self tick) class

  // BT-1942: Explicit `^` return of a nil-protocol intrinsic result.
  class tickReturnIsNil => ^(self tick) isNil
