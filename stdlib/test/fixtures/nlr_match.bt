// NlrMatch — non-local return inside match arm bodies

Value subclass: NlrMatch

  // ^ in a match arm should exit the method early
  findStatus: status =>
    status match: [
      #completed -> ^"done";
      #failed -> ^"error";
      _ -> nil
    ]
    "fallthrough"

  // Only some arms have ^, others fall through
  classify: value =>
    value match: [
      #stop -> ^"stopped early";
      _ -> nil
    ]
    "continued"
