// BT-1392: Value type fixture for testing local variable mutations inside
// ifTrue:/ifFalse:/ifTrue:ifFalse: blocks in non-actor context.

Value subclass: ConditionalLocalMutation

  // Single ifTrue: with captured local mutation
  testIfTrueSimple: flag =>
    x := 1
    flag ifTrue: [x := 2]
    x

  // Single ifFalse: with captured local mutation
  testIfFalseSimple: flag =>
    x := 1
    flag ifFalse: [x := 2]
    x

  // ifTrue:ifFalse: with captured local mutation in both branches
  testIfTrueIfFalse: flag =>
    x := 1
    flag ifTrue: [x := 2] ifFalse: [x := 3]
    x

  // Multiple captured mutations in one block
  testMultipleMutations: flag =>
    x := 1
    y := 10
    flag
      ifTrue: [
        x := 2
        y := 20
      ]
    x + y

  // Mutation with expression (not just literal)
  testMutationWithExpression: flag =>
    x := 5
    flag ifTrue: [x := x + 10]
    x

  // Sequential conditionals
  testSequentialConditionals: a and: b =>
    x := 0
    a ifTrue: [x := x + 1]
    b ifTrue: [x := x + 10]
    x
