// BT-854/BT-857: Fixture for testing NLR (non-local return) in value types
// Verifies that ^ (early return) works correctly inside blocks for value types
//
// Value types use field: (immutable). NLR tests exercise ^ inside do: blocks
// to verify early return propagation through the method.

Value subclass: NlrFieldMutation
  field: lastQuery = nil

  // NLR: returns the matched element via ^each
  findFirst: item in: items =>
    items do: [:each | each =:= item ifTrue: [^each]]
    nil

  // Returns a new self with lastQuery set to item, using with*: pattern
  findAndReturnSelf: item in: items =>
    updated := self withLastQuery: item
    items do: [:each | each =:= item ifTrue: [^updated]]
    updated

  // Normal NLR with no field mutations — exercises the tuple return format
  detect: aBlock in: items =>
    items do: [:each | (aBlock value: each) ifTrue: [^each]]
    nil

  // Tests the non-NLR path
  // Uses 1 > 2 (never true at runtime) rather than literal false to avoid BT-955 "literal boolean condition" warning
  findNone: items =>
    neverTrue := 1 > 2
    items do: [:each | neverTrue ifTrue: [^each]]
    nil

  // BT-857: Returns true if any element satisfies aBlock (early return via ^)
  anySatisfy: aBlock in: items =>
    items do: [:each | (aBlock value: each) ifTrue: [^true]]
    false

  lastQuery => self.lastQuery
