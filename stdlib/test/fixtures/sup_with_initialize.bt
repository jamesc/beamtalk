// BT-1542: Supervisor with initialize: hook that wires children together.
// initialize: calls which: on a sibling — this would deadlock without the
// caller-side dispatch fix.

Supervisor subclass: SupWithInitialize

  class children => #(SupInitChildA, SupInitChildB)

  class initialize: sup =>
    childA := sup which: SupInitChildA
    childA setValue: 42
