// Test protocol definitions for protocol_queries_test.bt (ADR 0068 Phase 2c).
// A dummy class is needed so the compiler generates register_class/0 which
// includes the protocol registration calls.
Protocol define: Displayable
  asString -> String
  printString -> String
Protocol define: HasSize
  size -> Integer
Value subclass: ProtocolTestProtoAnchor
