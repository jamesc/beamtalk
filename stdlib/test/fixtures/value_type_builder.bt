// ValueTypeBuilder - demonstrates immutable-update semantics via with*: (BT-833)
// Value types auto-generate withX:/withY: setters that return new instances

Value subclass: ValueTypeBuilder
  field: x = 0
  field: y = 0

  // Setter that assigns multiple fields sequentially (BT-833: sequential threading)
  setX: newX y: newY => (self withX: newX) withY: newY

  // Read-then-write: reads current field value, adds delta, writes back (BT-833)
  incrementX: delta => self withX: self.x + delta

  // Getters
  getX => self.x

  getY => self.y
