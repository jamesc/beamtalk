// BT-2880: Actor fixture reproducing the bug report's repro — a match:
// arm whose body is a multi-statement `[...] value` block that mutates
// `self.<state>` must thread actor state correctly and return the block's
// real last-statement value, not an internal state-threading Tuple. Mixes
// a native `nil ->` arm (the mutating one) with a `Pattern::Type` arm
// (`x :: Integer -> x`), matching the repro and exercising the
// chain-of-nested-cases codegen path (generate_match_chain).
//
// Unlike the bug report's own repro, `count` has a default value here
// rather than being a bare `state: count :: Integer` (no default) — a
// non-`typed` Actor with a no-default typed field plus an explicit
// `initialize` hits an unrelated, pre-existing gap where `handle_continue`
// never dispatches to `initialize` at all (also silently bypassing the
// uninitialized-state safety check), unrelated to this match: bug.
//
// `bumpMatchIfTrue:` covers the same bug in a second shape: an arm body
// that is itself a nested `ifTrue:`/`ifFalse:` mutation, with no `[...]
// value` wrapper at all.
//
// `bumpEitherOf:` covers a third shape (review follow-up): TWO different
// arms each mutate a DIFFERENT field via a `[...] value` block. Since only
// one arm fires per call, each must start from the same pre-match state —
// this pins that compiling arm 2 doesn't see any state leaked from
// compiling arm 1 (they're alternatives, not a sequence). Uses Integer
// literal patterns (1/2), not bare `true`/`false` — those are rejected at
// compile time with a diagnostic (BT-2883) rather than parsing as a
// boolean-literal test; use `x :: True`/`x :: False`/`x :: Boolean`
// instead (ADR 0107 Phase A).

Actor subclass: NilTypeMatchSelfMutationRegistry
  state: count :: Integer = 0
  state: otherCount :: Integer = 0

  initialize =>
    self.count := 0
    self.otherCount := 0
    nil

  bumpMatch -> Integer =>
    nil match: [
      nil -> [
        self.count := self.count + 1
        self.count
      ] value;
      x :: Integer -> x
    ]

  bumpMatchIfTrue: flag -> Integer =>
    nil match: [
      nil -> flag ifTrue: [
        self.count := self.count + 1
      ] ifFalse: [self.count := self.count - 1];
      x :: Integer -> x
    ]

  bumpEitherOf: choice -> Integer =>
    choice match: [
      1 -> [
        self.count := self.count + 1
        self.count
      ] value;
      2 -> [
        self.otherCount := self.otherCount + 1
        self.otherCount
      ] value
    ]

  currentCount => self.count

  currentOtherCount => self.otherCount
