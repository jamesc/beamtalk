// BT-1202: Fixture for non-local return (^) inside blocks in class methods.
// Simple ifTrue: early return from a class method.

Object subclass: ClassMethodNlrCheck

  class check: val =>
    (val class) =:= Integer ifTrue: [^99]
    nil
