// Fixture for BT-2818: Value subclass whose `asJson` result contains another
// asJson-implementing object (a JsonUser in the `lead` field). Exercises the
// recursive conversion in Json generate:.

Value subclass: JsonTeam
  field: teamName = ""
  field: lead = nil

  asJson => #{"team_name" => self.teamName, "lead" => self.lead}
