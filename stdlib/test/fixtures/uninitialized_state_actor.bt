// UninitializedStateActor — test fixture for BT-1949
//
// Actor with a typed-no-default field that the initialize method
// forgets to set. Spawn raises #instantiation_error with the
// UninitializedStateError details in the hint.

typed Actor subclass: UninitializedStateActor
  state: connection :: String
  state: count :: Integer = 0

  initialize -> Integer =>
    // Deliberately does NOT set self.connection
    self.count := 1

  getConnection -> String => self.connection

  getCount -> Integer => self.count
