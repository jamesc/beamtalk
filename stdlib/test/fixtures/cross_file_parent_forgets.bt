// BT-1976 fixture — cross-file parent whose `initialize` forgets its own
// typed-no-default field. Used together with
// `cross_file_child_of_forgetful.bt` to verify that validation of an
// inherited typed-no-default field works across compilation units.

typed Actor subclass: CrossFileParentForgets
  state: required :: String
  state: counter :: Integer = 0

  initialize -> Integer =>
    // Deliberately does NOT set self.required — the missing field must be
    // caught by the child's post-initialize check, which reads the parent's
    // field metadata from `__beamtalk_meta/0` (no AST available).
    self.counter := 1

  getRequired -> String => self.required

  getCounter -> Integer => self.counter
