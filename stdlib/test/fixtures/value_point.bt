// ValuePoint — a Point class declared with `Value subclass:` (BT-923)
// Tests auto-generated getters, with*: setters, and keyword constructor

Value subclass: ValuePoint
  field: x = 0
  field: y = 0

  // User-defined method: distance squared from origin
  distanceSquared => (self.x * self.x) + (self.y * self.y)
