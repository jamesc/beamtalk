// BT-1140: Actor fixture for testing field-write blocks promoted to Tier 2 via
// user-defined HOMs. Verifies that self.field := ... inside a block passed to a
// user-defined HOM correctly threads field state back to the caller.

Actor subclass: HomFieldWriteActor
  state: sum = 0

  // User-defined HOM: calls aBlock for each element in #(1, 2, 3, 4, 5).
  // The `last :=` write activates the stateful do: path so that
  // aBlock value: each is called with Tier 2 StateAcc threading.
  applyAll: aBlock =>
    last := nil
    #(1, 2, 3, 4, 5) do: [:each | last := aBlock value: each]
    last

  getSum => self.sum

  // Test: field write via user-defined HOM — self.sum accumulates correctly
  // [:x | self.sum := self.sum + x] over #(1,2,3,4,5) = 15
  testFieldWriteViaHOM =>
    self.sum := 0
    self applyAll: [:x | self.sum := self.sum + x]
    self.sum
