// BT-2709/BT-2710 fixture: a tiny value-type money amount (in cents) that
// overloads the arithmetic operators `+ - *` (so `aMoney + bMoney` dispatches
// to `Money>>+`) and the comparison operators `< > <= >=` (so `aMoney < bMoney`
// dispatches to `Money>><` rather than silently comparing by Erlang term-order).

Value subclass: Money
  field: cents :: Integer = 0

  /// The amount in cents.
  cents -> Integer => self.cents

  /// Add two money amounts (receiver-dispatched `+`).
  + other :: Money -> Money => (Money new) withCents: self.cents + other cents

  /// Subtract two money amounts.
  - other :: Money -> Money => (Money new) withCents: self.cents - other cents

  /// Scale a money amount by an integer factor.
  * factor :: Integer -> Money => (Money new) withCents: self.cents * factor

  /// Less than, by cents (receiver-dispatched `<`).
  < other :: Money -> Boolean => self.cents < other cents

  /// Greater than, by cents.
  > other :: Money -> Boolean => self.cents > other cents

  /// Less than or equal, by cents.
  <= other :: Money -> Boolean => self.cents <= other cents

  /// Greater than or equal, by cents.
  >= other :: Money -> Boolean => self.cents >= other cents
