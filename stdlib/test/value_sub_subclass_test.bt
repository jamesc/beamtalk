// BT-1559: Tests for Value sub-subclass instantiation.
// ValueBaseShape (Value subclass) → ValueSubCircle (sub-subclass).
// Exercises: new, new:, keyword constructor, inherited getters/setters.
//
// Fixtures: stdlib/test/fixtures/value_base_shape.bt (ValueBaseShape)
//           stdlib/test/fixtures/value_sub_circle.bt (ValueSubCircle)

TestCase subclass: ValueSubSubclassTest

  // --- new ---
  testNewCreatesInstanceWithDefaults =>
    c := ValueSubCircle new
    self assert: c radius equals: 1.0
    self assert: c color equals: "black"

  testNewClassIsCorrect =>
    c := ValueSubCircle new
    self assert: c class equals: ValueSubCircle

  // --- new: ---
  testNewWithMapSetsOwnField =>
    c := ValueSubCircle new: #{#radius => 5.0}
    self assert: c radius equals: 5.0
    self assert: c color equals: "black"

  testNewWithMapSetsInheritedField =>
    c := ValueSubCircle new: #{#color => "red"}
    self assert: c color equals: "red"
    self assert: c radius equals: 1.0

  testNewWithMapSetsBothFields =>
    c := ValueSubCircle new: #{#radius => 3.0, #color => "blue"}
    self assert: c radius equals: 3.0
    self assert: c color equals: "blue"

  // --- keyword constructor ---
  testKeywordConstructorOwnField =>
    c := ValueSubCircle radius: 7.0
    self assert: c radius equals: 7.0
    self assert: c color equals: "black"

  // --- class-side factory ---
  testClassSideFactory =>
    c := ValueSubCircle withRadius: 9.0
    self assert: c radius equals: 9.0
    self assert: c class equals: ValueSubCircle

  // --- withX: setters ---
  testWithOwnFieldSetter =>
    c := ValueSubCircle new
    c2 := c withRadius: 42.0
    self assert: c2 radius equals: 42.0
    // Original unchanged
    self assert: c radius equals: 1.0

  testWithInheritedFieldSetter =>
    c := ValueSubCircle new
    c2 := c withColor: "green"
    self assert: c2 color equals: "green"
    // Original unchanged
    self assert: c color equals: "black"

  // --- user-defined method using both fields ---
  testUserMethodUsesBothFields =>
    c := ValueSubCircle new: #{#color => "red", #radius => 2.5}
    self assert: c describe equals: "red circle r=2.5"
