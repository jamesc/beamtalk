// BUnit tests for Announcements stdlib veneer (BT-2443)

TestCase subclass: AnnouncementsTest
  field: announcer = nil

  setUp => self withAnnouncer: Announcer new

  // --- Announcer basics ---
  testAnnouncerNew => self assert: self.announcer class equals: Announcer

  testAnnouncerNewMintsDistinct =>
    other := Announcer new
    self deny: (self.announcer == other)

  // --- Subscribe and announce (async) ---
  testWhenDoSubscribes =>
    sub := self.announcer when: TestEvent do: [:e | nil]
    self assert: sub class equals: Subscription
    self assert: sub isActive equals: true
    sub unsubscribe

  testAnnounceFiresHandler =>
    received := AtomicCounter new: #announcementsTestReceived
    self.announcer when: TestEvent do: [:e | received incrementBy: e payload]
    self.announcer announce: (TestEvent payload: 42)
    Timer sleep: 50
    self assert: received value equals: 42
    received delete

  // --- Unsubscribe ---
  testUnsubscribeStopsDelivery =>
    received := AtomicCounter new: #announcementsTestUnsub
    sub := self.announcer when: TestEvent do: [:e | received increment]
    self.announcer announce: (TestEvent payload: 1)
    Timer sleep: 50
    sub unsubscribe
    self.announcer announce: (TestEvent payload: 2)
    Timer sleep: 50
    self assert: received value equals: 1
    received delete

  testUnsubscribeIdempotent =>
    sub := self.announcer when: TestEvent do: [:e | nil]
    sub unsubscribe
    sub unsubscribe
    self assert: sub isActive equals: false

  // --- isActive ---
  testIsActiveAfterSubscribe =>
    sub := self.announcer when: TestEvent do: [:e | nil]
    self assert: sub isActive equals: true
    sub unsubscribe

  testIsActiveAfterUnsubscribe =>
    sub := self.announcer when: TestEvent do: [:e | nil]
    sub unsubscribe
    self assert: sub isActive equals: false

  // --- doOnce ---
  testDoOnceFiresOnce =>
    received := AtomicCounter new: #announcementsTestDoOnce
    self.announcer when: TestEvent doOnce: [:e | received increment]
    self.announcer announce: (TestEvent payload: 1)
    Timer sleep: 50
    self.announcer announce: (TestEvent payload: 2)
    Timer sleep: 50
    self assert: received value equals: 1
    received delete

  // --- SystemAnnouncer ---
  testSystemAnnouncerCurrent =>
    sys := SystemAnnouncer current
    self assert: sys class equals: SystemAnnouncer

  testSystemAnnouncerIsAnnouncer =>
    sys := SystemAnnouncer current
    self assert: (sys isKindOf: Announcer) equals: true

  testSystemAnnouncerAnnounceAndWaitRaises =>
    sys := SystemAnnouncer current
    self should: [
      sys announceAndWait: (TestEvent payload: 1)
    ] raise: #unsupported_operation

  // --- announceAndWait (sync) ---
  testAnnounceAndWaitSynchronous =>
    received := AtomicCounter new: #announcementsTestSync
    self.announcer when: TestEvent do: [:e | received incrementBy: e payload]
    self.announcer announceAndWait: (TestEvent payload: 7)
    // No sleep needed — announceAndWait is synchronous
    self assert: received value equals: 7
    received delete

  // --- announceAndWait:timeout: (custom timeout, exercises announceAndWaitOn/3) ---
  testAnnounceAndWaitWithCustomTimeout =>
    received := AtomicCounter new: #announcementsTestSyncTimeout
    self.announcer when: TestEvent do: [:e | received incrementBy: e payload]
    self.announcer announceAndWait: (TestEvent payload: 3) timeout: 5000
    // No sleep — announceAndWait:timeout: is synchronous.
    self assert: received value equals: 3
    received delete

  // --- unsubscribe: receiver (bulk-remove by pid, exercises unsubscribeReceiver/2) ---
  testUnsubscribeReceiverByPid =>
    received := AtomicCounter new: #announcementsTestUnsubReceiverPid
    sub1 := self.announcer when: TestEvent do: [:e | received increment]
    sub2 := self.announcer when: TestEvent do: [:e | received increment]
    // Both subscriptions are held by the test process; node subscriber is a
    // raw Erlang pid (BT Pid — maps directly to pid()). Passing it to
    // unsubscribe: drops all subscriptions for that receiver at once.
    node := (self.announcer subscribersOf: TestEvent) first
    subscriberPid := node subscriber
    self.announcer unsubscribe: subscriberPid
    self.announcer announce: (TestEvent payload: 1)
    Timer sleep: 50
    self assert: received value equals: 0
    self assert: sub1 isActive equals: false
    self assert: sub2 isActive equals: false
    received delete

  // --- MRO matching ---
  testMROMatchingSubclassDelivery =>
    received := AtomicCounter new: #announcementsTestMRO
    self.announcer when: ParentEvent do: [:e | received increment]
    self.announcer announce: (ChildEvent detail: "test")
    Timer sleep: 50
    self assert: received value equals: 1
    received delete

  // --- Per-instance isolation (BT-2454) ---
  testDistinctAnnouncersAreIsolated =>
    received := AtomicCounter new: #announcementsTestIsolation
    other := Announcer new
    self.announcer when: TestEvent do: [:e | received increment]
    // An event on a *different* announcer must NOT reach this subscription.
    other announce: (TestEvent payload: 1)
    Timer sleep: 50
    self assert: received value equals: 0
    // ...but an event on the same announcer still does (sanity).
    self.announcer announce: (TestEvent payload: 1)
    Timer sleep: 50
    self assert: received value equals: 1
    received delete

  testSystemAnnouncerStillReceivesSystemEvents =>
    received := AtomicCounter new: #announcementsTestSystemBus
    sys := SystemAnnouncer current
    sub := sys when: TestEvent do: [:e | received increment]
    sys announce: (TestEvent payload: 1)
    Timer sleep: 50
    self assert: received value equals: 1
    // A per-instance announcer is isolated from the system bus.
    self.announcer announce: (TestEvent payload: 2)
    Timer sleep: 50
    self assert: received value equals: 1
    sub unsubscribe
    received delete
