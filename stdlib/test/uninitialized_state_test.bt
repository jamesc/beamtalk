// Tests for BT-1949: post-initialize check for typed-no-default fields.
//
// Uninitialized typed fields cause spawn to raise #instantiation_error
// with UninitializedStateError details in the hint.
//
// Fixtures:
//   stdlib/test/fixtures/typed_no_default_actor.bt   (properly initializes)
//   stdlib/test/fixtures/uninitialized_state_actor.bt (forgets to initialize)
//   stdlib/test/fixtures/nil_allowed_state_actor.bt   (nilable field, nil is valid)

TestCase subclass: UninitializedStateTest

  // === Success: typed-no-default field properly initialized ===
  testTypedNoDefaultFieldInitialized =>
    a := TypedNoDefaultActor spawn
    self assert: a getLabel equals: "initialized"

  testTypedNoDefaultFieldWithDefaultWorks =>
    a := TypedNoDefaultActor spawn
    self assert: a getCount equals: 0

  // === Failure: typed-no-default field left nil ===
  testUninitializedTypedFieldRaisesError =>
    self should: [UninitializedStateActor spawn] raise: #instantiation_error

  testUninitializedErrorContainsClassName =>
    e := [UninitializedStateActor spawn] on: Exception do: [:ex | ex]
    self assert: e kind equals: #instantiation_error
    self assert: (e message includesSubstring: "UninitializedStateActor")

  testUninitializedErrorHintContainsFieldName =>
    e := [UninitializedStateActor spawn] on: Exception do: [:ex | ex]
    self assert: e kind equals: #instantiation_error
    self assert: (e hint includesSubstring: "connection")

  testUninitializedErrorHintContainsTypeName =>
    e := [UninitializedStateActor spawn] on: Exception do: [:ex | ex]
    self assert: e kind equals: #instantiation_error
    self assert: (e hint includesSubstring: "String")

  // === Nilable typed-no-default field: nil is valid, no error ===
  testNilAllowedFieldLeftNilSpawnsSuccessfully =>
    a := NilAllowedStateActor spawn
    self assert: a getLabel equals: nil

  testNilAllowedFieldOtherStateWorks =>
    a := NilAllowedStateActor spawn
    self assert: a getCount equals: 1
