// BT-1054: Verify that pure-BT tail-recursive loop methods do not blow the
// stack for large iteration counts.  Core Erlang `call` in tail position is
// automatically TCO'd by the Erlang compiler, so 100 000 iterations must
// complete without a stack-overflow crash.

TestCase subclass: CountedLoopsTcoTest

  testTimesRepeatLargeCount =>
    // 100 000 timesRepeat: with a no-op block — verifies TCO on the simple path
    // (no local mutations, no self-sends).  BUnit passes if no exception is raised.
    100000 timesRepeat: []

  testToDoLargeRange =>
    // Integer to:do: over 100 000 values — verifies TCO and that outer-variable
    // mutation threads back to the caller (BT-2308).  The direct-params loop keeps
    // this tail-recursive, so 100 000 iterations complete without a stack overflow.
    last := 0
    1 to: 100000 do: [:i | last := i]
    self assert: last equals: 100000

  testToByDoLargeRange =>
    // Integer to:by:do: over 100 000 values — verifies TCO and outer-variable
    // mutation threading (BT-2308).
    last := 0
    1
      to: 100000
      by: 1
      do: [:i | last := i]
    self assert: last equals: 100000

  testToByDoNegativeStep =>
    // Integer to:by:do: with negative step over 100 000 values — verifies TCO and
    // outer-variable mutation threading (BT-2308).
    last := 0
    100000
      to: 1
      by: -1
      do: [:i | last := i]
    self assert: last equals: 1

  testToByDoZeroStepIsNoop =>
    // to:by:do: with zero step — body must never execute; asserts early exit
    count := 0
    1
      to: 100000
      by: 0
      do: [:_ | count := count + 1]
    self assert: count equals: 0
