// Tests for block (closure) evaluation — argument passing, arity, whileTrue/False,
// valueWithArguments:, closure variable capture, early return with ^, and
// perform:/perform:withArguments: on structural intrinsics (BT-2812, BT-2908)

TestCase subclass: BlocksTest

  testBlockEvaluation =>
    self assert: ([:x | x + 1] value: 5) equals: 6
    // Block with two arguments
    self assert: ([:x :y | x + y] value: 3 value: 4) equals: 7
    // Block with no arguments (value message)
    self assert: [42] value equals: 42
    // Block with expression body
    self assert: ([:n | n * n] value: 5) equals: 25
    // Nested arithmetic in block
    self assert: ([:a | a + a * 2] value: 3) equals: 9
    // Block returning constant
    self assert: ([:x | 100] value: 999) equals: 100
    // Block with subtraction
    self assert: ([:a :b | a - b] value: 10 value: 3) equals: 7
    // Block with three arguments
    self
      assert: ([:x :y :z | x + y + z]
        value: 1
        value: 2
        value: 3)
      equals: 6
    // Nested blocks - outer returns inner block that captures x
    self assert: ([[:x | [:y | x + y]] value: 10] value value: 5) equals: 15
    // Higher-order block (makeAdder pattern)
    self assert: ([[:n | [:x | x + n]] value: 5] value value: 10) equals: 15
    // Complex expression in block body
    self assert: ([:x | x * 2 + 1] value: 5) equals: 11

  testReturnStatements =>
    // Explicit return with ^ (returns from block)
    self assert: ([:x | ^x + 10] value: 5) equals: 15
    // Explicit return of literal
    self assert: [^42] value equals: 42
    // Implicit return (last expression) - same behavior
    self assert: ([:x | x + 10] value: 5) equals: 15
    // whileTrue: with false condition (returns immediately)
    self assert: ([false] whileTrue: [42]) equals: nil

  testBasicClosureCapture =>
    // Simple closure capturing outer variable
    outerVar := 10
    self assert: outerVar equals: 10
    self assert: ([:x | x + outerVar] value: 5) equals: 15
    // Nested closure with capture
    makeAdder := [:n | [:x | x + n]]
    addFive := makeAdder value: 5
    self assert: (addFive value: 10) equals: 15

  testBlockValuewitharguments =>
    // Block with array of arguments
    self assert: ([:x :y | x + y] valueWithArguments: #(3, 4)) equals: 7
    // Zero-arg block
    self assert: ([42] valueWithArguments: #()) equals: 42
    // Single-arg block
    self assert: ([:x | x * 2] valueWithArguments: #(5)) equals: 10

  testBlockArity =>
    // Zero-argument block arity
    self assert: [42] arity equals: 0
    // One-argument block arity
    self assert: [:x | x + 1] arity equals: 1
    // Two-argument block arity
    self assert: [:x :y | x + y] arity equals: 2
    // Three-argument block arity
    self assert: [:x :y :z | x + y + z] arity equals: 3

  testWhilefalse =>
    // whileFalse: with true condition (returns immediately)
    self assert: ([true] whileFalse: [42]) equals: nil

  testPerformOnPureBlockValueSelectors =>
    // BT-2812: value/value:/value:value:/value:value:value: reached via
    // perform:withArguments: (bypassing the call-site interception) used to
    // resolve to the wrong internal intrinsic name and raise a confusing
    // does_not_understand. Pure (Tier 1) blocks now get a real fix.
    self assert: ([42] perform: #value withArguments: #()) equals: 42
    self assert: ([:x | x + 1] perform: #value: withArguments: #(3)) equals: 4
    self assert: ([:x :y |
      x + y
    ] perform: #value:value: withArguments: #(3, 4)) equals: 7
    self assert: ([:x :y :z |
      x + y + z
    ] perform: #value:value:value: withArguments: #(1, 2, 3)) equals: 6

  testPerformOnStatefulBlockRaisesClearError =>
    // BT-2812: a stored (Tier 2) block mutates captured state via a threaded
    // StateAcc that only a call-site-aware caller can supply — perform:
    // has no such state, so this now raises a clear, purpose-built error
    // instead of the wrong-selector does_not_understand it used to.
    count := 0
    statefulBlock := [:x | count := count + x]
    self should: [
      statefulBlock perform: #value: withArguments: #(3)
    ] raise: #stateful_block_dispatch

  testPerformWithWrongArityOnPureBlockAlsoRaisesSameErrorKind =>
    // BT-2812 code review: erlang:is_function/2 arity comparison can't tell a
    // genuine Tier 2 (stateful) block from a Tier 1 (pure) block simply called
    // with the wrong argument count — both present as the receiver's fun
    // being one arity larger than the selector expects. A pure 2-arg block
    // called via #value: (1-arg) hits the same stateful_block_dispatch
    // branch even though it captures no state at all, so the error kind is
    // reused for both causes and the message/hint deliberately don't assert
    // a specific one.
    self should: [
      [:a :b | a + b] perform: #value: withArguments: #(3)
    ] raise: #stateful_block_dispatch

  testPerformWithWrongArityOnStatefulBlockRaisesAStructuredErrorNotACrash =>
    // BT-2812 code review (BT-2892 tracks improving this): the arity
    // ambiguity also cuts the other way — a genuinely Tier 2 (stateful)
    // 0-arg block has raw arity 1 (StateAcc only), which satisfies
    // value:'s Tier 1 check, so the fallback misapplies the caller's
    // argument into the StateAcc slot. This does NOT crash raw: an outer
    // safety net already converts the resulting internal map-shape failure
    // into a clean, catchable structured error (currently #type_error, not
    // the more informative #stateful_block_dispatch — see BT-2892). This
    // test pins "still a structured error, not a raw crash" rather than the
    // exact kind, since the precise kind is an accident of unrelated
    // machinery, not a designed contract.
    count := 0
    statefulZeroArgBlock := [count := count + 1]
    caught := [
      statefulZeroArgBlock perform: #value: withArguments: #(42)
    ] on: Exception do: [:e | e]
    self assert: (caught isKindOf: Exception)

  testPerformOnPureWhileTrueAndWhileFalseSelectors =>
    // BT-2908: whileTrue:/whileFalse: reached via perform:withArguments:
    // (bypassing the call-site interception) used to resolve to the wrong
    // internal intrinsic name and raise a confusing does_not_understand.
    // Pure (Tier 1) condition/body blocks now run a real generic loop.
    self assert: ([
      false
    ] perform: #whileTrue: withArguments: #([42])) equals: nil
    self assert: ([
      true
    ] perform: #whileFalse: withArguments: #([42])) equals: nil
    counter := AtomicCounter new: #bt2908WhileTrueCounter
    [
      [
        counter value < 3
      ] perform: #whileTrue: withArguments: #([counter increment])
      self assert: counter value equals: 3
    ] ensure: [counter delete]

  testPerformOnPureRepeatSelector =>
    // BT-2908: repeat reached via perform:withArguments: — a pure receiver
    // block now runs a real generic infinite loop, exited here via a raised
    // exception (repeat has no other way to stop) rather than the
    // wrong-selector does_not_understand it used to hit immediately.
    counter := AtomicCounter new: #bt2908RepeatCounter
    [
      result := [
        [
          counter increment
          (counter value >= 3) ifTrue: [Error signal: "done"]
        ] perform: #repeat withArguments: #()
      ] on: Error do: [:e | counter value]
      self assert: result equals: 3
    ] ensure: [counter delete]

  testPerformOnPureOnDoSelector =>
    // BT-2908: on:do: reached via perform:withArguments: now runs the same
    // try/catch/matches_class semantics generate_on_do produces for a
    // literal `on:do:` send, for pure (Tier 1) receiver/handler blocks.
    self assert: ([
      1 / 0
    ] perform: #on:do: withArguments: #(Error, [:e |
      "caught"
    ])) equals: "caught"
    self assert: ([
      42
    ] perform: #on:do: withArguments: #(Error, [:e | "unused"])) equals: 42
    self assert: ([
      1 / 0
    ] perform: #on:do: withArguments: #(Error, [
      "zero-arg handler"
    ])) equals: "zero-arg handler"

  testPerformOnPureEnsureSelector =>
    // BT-2908: ensure: reached via perform:withArguments: now runs cleanup
    // on both the success and error paths, matching generate_ensure's
    // literal-send semantics, for pure (Tier 1) receiver/cleanup blocks.
    counter := AtomicCounter new: #bt2908EnsureCounter
    [
      self assert: ([
        42
      ] perform: #ensure: withArguments: #([counter increment])) equals: 42
      self assert: counter value equals: 1
      caught := [
        [1 / 0] perform: #ensure: withArguments: #([counter increment])
      ] on: Exception do: [:e | "caught"]
      self assert: caught equals: "caught"
      self assert: counter value equals: 2
    ] ensure: [counter delete]

  testPerformOnStatefulLoopBlockRaisesClearError =>
    // BT-2908: a stateful (Tier 2) condition or body block mutates captured
    // state via a threaded StateAcc that only a call-site-aware caller can
    // supply — perform: has no such state, so this raises a clear,
    // purpose-built error instead of a wrong-selector does_not_understand.
    // Exact repro from docs/beamtalk-language-features.md's former "known
    // limitation" note.
    i := 0
    self should: [
      [i < 3] perform: #whileTrue: withArguments: #([i := i + 1])
    ] raise: #stateful_block_dispatch
    count := 0
    statefulBody := [count := count + 1]
    self should: [
      [false] perform: #whileTrue: withArguments: #(statefulBody)
    ] raise: #stateful_block_dispatch
    self should: [
      statefulBody perform: #repeat withArguments: #()
    ] raise: #stateful_block_dispatch

  testPerformOnStatefulExceptionBlockRaisesClearError =>
    // BT-2908: same Tier 2 gap as the loop family above, for on:do:/ensure:'s
    // receiver, handler, and cleanup blocks.
    count := 0
    statefulReceiver := [count := count + 1]
    self should: [
      statefulReceiver perform: #on:do: withArguments: #(Error, [:e | "unused"])
    ] raise: #stateful_block_dispatch
    self should: [
      [
        1 / 0
      ] perform: #on:do: withArguments: #(Error, [:e | count := count + 1])
    ] raise: #stateful_block_dispatch
    self should: [
      statefulReceiver perform: #ensure: withArguments: #([nil])
    ] raise: #stateful_block_dispatch
    self should: [
      [42] perform: #ensure: withArguments: #(statefulReceiver)
    ] raise: #stateful_block_dispatch

  testPerformOnDoNonMatchingExceptionClassReraisesToOuterHandler =>
    // BT-2908 adversarial review: a non-matching exception class must
    // re-raise (not invoke the handler) through the perform: path too,
    // exactly like a literal on:do: send (mirrors custom_exceptions_test.bt's
    // testNonMatchingClassTypeError).
    result := [
      [
        MyCustomError signal: "no"
      ] perform: #on:do: withArguments: #(TypeError, [:e | "wrong"])
    ] on: Exception do: [:e | "correct"]
    self assert: result equals: "correct"

  performOnDoNlrHelper =>
    [
      Error signal: "trigger"
    ] perform: #on:do: withArguments: #(Error, [:e | ^42])
    99

  testPerformOnDoNonLocalReturnPropagatesThroughGenericDispatch =>
    // BT-2908 adversarial review: on:do:'s handler block reached via
    // perform: must let a ^ (non-local return) propagate to the enclosing
    // method exactly like the AST-driven on:do: does. Proven via a helper
    // method whose ^ inside the perform:-dispatched handler short-circuits
    // before its own trailing expression (99) is reached — if NLR were
    // caught or swallowed by the generic fallback, this would return 99
    // (or crash) instead of 42.
    self assert: self performOnDoNlrHelper equals: 42

  performEnsureNlrHelper: counter =>
    [^42] perform: #ensure: withArguments: #([counter increment])
    99

  testPerformOnEnsureNonLocalReturnPropagatesThroughGenericDispatch =>
    // BT-2908 adversarial review: ensure:'s protected block reached via
    // perform: must let a ^ propagate after cleanup runs exactly once,
    // exactly like the AST-driven ensure: does. Same short-circuit proof as
    // the on:do: test above, plus confirms cleanup still ran on the NLR path.
    counter := AtomicCounter new: #bt2908EnsureNlrCounter
    [
      self assert: (self performEnsureNlrHelper: counter) equals: 42
      self assert: counter value equals: 1
    ] ensure: [counter delete]

  testPerformOnDoWithZeroArgStatefulHandlerSilentlyMisfiresInsteadOfErroring =>
    // BT-2908 review: on:do:'s handler dispatch shares the arity-1 ambiguity
    // BT-2812 documented for blockValue* (deferred to BT-2892) — a genuinely
    // Tier 2 0-arg handler has raw arity 1 (StateAcc only), indistinguishable
    // from a pure 1-arg handler, so it gets misapplied as
    // `apply Handler (ExObj)` instead of raising stateful_block_dispatch.
    // Empirically checked (not assumed): unlike BT-2812's blockValue* variant,
    // where the misapplied block's internal maps:get/maps:put hits a badarg
    // an outer safety net converts to a clean #beamtalk_error{}, this
    // variant doesn't crash or error at all — a 0-arg block using direct-
    // params state threading (BT-1275) just tolerates ExObj as a stand-in
    // StateAcc and returns a garbage {Result, NewState} tuple silently, with
    // the original exception dropped rather than propagated or reported.
    // Pinned as the observed behavior for this specific variant of the
    // deferred BT-2892 ambiguity — not a regression from this PR (the same
    // arity check already exists for value:/etc. via BT-2812), but the
    // silent-data-loss shape is worth flagging for whoever picks up BT-2892.
    count := 0
    statefulZeroArgHandler := [count := count + 1]
    result := [
      1 / 0
    ] perform: #on:do: withArguments: #(Error, statefulZeroArgHandler)
    self assert: (result isKindOf: Tuple)
