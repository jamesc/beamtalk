// File I/O tests

TestCase subclass: FileIoTest

  testFileExistenceChecks =>
    self deny: (File exists: "target/bt-test-tmp/nonexistent_xyzzy.txt")

  testFileWritingAndReading =>
    self assert: (File writeAll: "target/bt-test-tmp/test.txt" contents: "Hello, Beamtalk!") isOk
    self assert: (File readAll: "target/bt-test-tmp/test.txt") unwrap equals: "Hello, Beamtalk!"
    self assert: (File exists: "target/bt-test-tmp/test.txt")

  testOverwriteExistingFile =>
    self assert: (File writeAll: "target/bt-test-tmp/test.txt" contents: "New content") isOk
    self assert: (File readAll: "target/bt-test-tmp/test.txt") unwrap equals: "New content"

  testSpecialCharacters =>
    self assert: (File writeAll: "target/bt-test-tmp/special.txt" contents: "Hello, World! @#$%") isOk
    self assert: (File readAll: "target/bt-test-tmp/special.txt") unwrap equals: "Hello, World! @#$%"

  testEmptyFile =>
    self assert: (File writeAll: "target/bt-test-tmp/empty.txt" contents: "") isOk
    self assert: (File readAll: "target/bt-test-tmp/empty.txt") unwrap equals: ""
    self assert: (File exists: "target/bt-test-tmp/empty.txt")

  testAbsolutePathsAccepted =>
    // ADR 0063: absolute paths are now allowed — round-trip via temp directory
    tmp := File tempDirectory
    path := tmp ++ "/_bt_test_abs_roundtrip.txt"
    self assert: (File writeAll: path contents: "absolute") isOk
    self assert: (File readAll: path) unwrap equals: "absolute"
    (File delete: path) unwrap

  testErrorPathsReadall =>
    // readAll: nonexistent file returns file_not_found error
    result := File readAll: "target/bt-test-tmp/no_such_file_xyz.txt"
    self assert: result isError
    self assert: (result error printString includesSubstring: "file not found")
    // readAll: non-string path
    @expect type
    self should: [File readAll: 42] raise: #type_error

  testErrorPathsWriteallContents =>
    // writeAll: non-string path
    @expect type
    self should: [File writeAll: 42 contents: "data"] raise: #type_error
    // writeAll: non-string contents
    @expect type
    self should: [
      File writeAll: "target/bt-test-tmp/test.txt" contents: 42
    ] raise: #type_error

  testSubdirectoryCreation =>
    // writeAll: creates parent directories automatically
    self assert: (File writeAll: "target/bt-test-tmp/subdir/nested.txt" contents: "nested") isOk
    self assert: (File readAll: "target/bt-test-tmp/subdir/nested.txt") unwrap equals: "nested"

  testUnicodeContent =>
    self assert: (File writeAll: "target/bt-test-tmp/unicode.txt" contents: "Hello 世界 🌍") isOk
    self assert: (File readAll: "target/bt-test-tmp/unicode.txt") unwrap equals: "Hello 世界 🌍"
