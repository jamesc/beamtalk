// BT-2214: BUnit-level coverage for `SystemNavigation implementorsOf:` — finds
// all classes that directly define a given selector. Backs System Browser-style
// navigation ("who else has this method?").
//
// `implementorsOf:` is an instance method on `SystemNavigation`, reached via
// the `default` (or future scoped) constructor. The class-side surface is
// constructors only — query logic stays on the instance so the iteration
// runs as plain Erlang in the caller and avoids the class-gen_server
// self-deadlock that hits when a class method walks the registry and the
// walk reaches its own class.
//
// Behavioural tests (happy path, multi-implementor, no-implementor, stdlib
// participation) live in the E2E REPL-protocol suite at
// tests/repl-protocol/cases/workspace_native_api.btscript, which runs in
// workspace_mode and has the live class registry populated with user classes.

TestCase subclass: SystemNavigationImplementorsTest

  // --- selector existence ---
  testIncludesSelectorImplementorsOf =>
    self assert: (SystemNavigation includesSelector: #implementorsOf:)

  testIncludesSelectorDefault =>
    self assert: (SystemNavigation class includesSelector: #default)

  // --- composition primitives must be in place ---

  // The implementation iterates the navigation scope (via `allClasses`)
  // and filters by includesSelector:. That primitive has to be present on
  // Behaviour.
  testCompositionPrimitivesPresent =>
    self assert: (SystemNavigation includesSelector: #allClasses)
    self assert: (Behaviour includesSelector: #includesSelector:)

  // --- BT-2302: xref-backed read path + miss-policy fallback ---
  //
  // `implementorsOf:` now reads the implementor set from the runtime-maintained
  // xref methods table (`beamtalk_xref:implementors_of_bt/1`) instead of probing
  // `includesSelector:` over every class in the scope, falling back to the
  // direct probe only for loaded-but-unindexed classes. The behavioural
  // coverage — that a registry-loaded class artificially purged from the index
  // still resolves via fallback and emits exactly one `xref_miss` warning —
  // lives in the runtime EUnit suite
  // (`beamtalk_xref_tests:nav_query_miss_policy_test_`), because the live class
  // registry + xref server are required. The check below covers the shared
  // owner-tag/class-side -> class-object resolver that maps the indexed rows.
  testHelperSenderClassForIsDefined =>
    self assert: (SystemNavigation includesSelector: #senderClassFor:classSide:)

  // --- BT-2304 / ADR 0087 Phase 6: synthetic auto-accessor parity exception ---
  //
  // Compiler-generated auto-accessors for `Value subclass:` classes (the
  // `field/1` getters and `withField:/2` setters from value_type_codegen.rs)
  // have no user source text, so the pre-index source-scan queries could not
  // see them. Under the xref index they ride the same write path with
  // `source_status => synthetic` and a derived `synthetic_origin`, so
  // `implementorsOf:` on an auto-accessor is now NON-empty. This is a documented
  // parity exception — more complete than before, not a regression.
  //
  // The index-level behavioural assertions (the synthetic row appears in
  // `implementors_of`, carries `source_status => synthetic`, contributes the
  // slot-type reference, and sends nothing) live in the runtime EUnit suite
  // `beamtalk_xref_tests:synthetic_accessor_visibility_test_` — the live xref
  // server is required and the BUnit harness does not start it. The structural
  // check below confirms the auto-accessor really is a dispatchable method on a
  // stdlib value class (the registry is populated under BUnit): `ChangeEntry` is
  // a `Value subclass:` whose `seq` slot's `withSeq:` setter is compiler-emitted
  // (the class hand-defines the `seq` getter but no setter).
  testSyntheticAutoSetterIsADispatchableMethod =>
    self assert: (ChangeEntry includesSelector: #withSeq:)
