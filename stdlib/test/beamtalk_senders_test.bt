// BT-2214: BUnit-level coverage for `SystemNavigation sendersOf:` — finds all
// call sites of a given selector across the loaded class registry. Backs
// System Browser-style navigation ("who calls this method?").
//
// `sendersOf:` is an instance method on `SystemNavigation`, reached via
// the `default` (or future scoped) constructor. See the note in
// `beamtalk_implementors_test.bt` for why the class side is constructors
// only and queries live on the instance.
//
// Behavioural tests (happy path, multiple call sites in one method,
// no-senders, stdlib senders, Symbol type check) live in the E2E
// REPL-protocol suite at tests/repl-protocol/cases/workspace_native_api.btscript,
// which runs in workspace_mode and has the live class registry populated
// with user classes.

TestCase subclass: SystemNavigationSendersTest

  // --- selector existence ---
  testIncludesSelectorSendersOf =>
    self assert: (SystemNavigation includesSelector: #sendersOf:)

  // --- composition primitives must be in place ---

  // The implementation walks aClass methods, fetches each method via `>>`,
  // reads its source, and asks the compiler to find matching MessageSend
  // lines. All of those primitives have to be present.
  testCompositionPrimitivesPresent =>
    self assert: (Behaviour includesSelector: #methods)
    self assert: (Behaviour includesSelector: #'>>')
    self assert: (CompiledMethod includesSelector: #source)

  // The internal helper `collectSendersFor:in:into:` factors out per-class
  // iteration so it can be unit-checked separately.
  testHelperCollectSendersIsDefined =>
    self assert: (SystemNavigation includesSelector: #collectSendersFor:in:into:)

  // --- BT-2195: class-side scanning ---
  //
  // Behavioural assertions (does the metaclass walk produce hits?) live in
  // the REPL-protocol E2E suite — the BUnit harness does not start the
  // compiler-port process, so `findSendersIn:` returns `[]` here regardless
  // of the source's contents. The BUnit checks below cover the parts that
  // do not require the compiler port: that `>>` on a metaclass returns a
  // CompiledMethod with non-empty source, and that the underlying
  // primitives `methods` / `respondsTo:` work on a metaclass scope.

  // `SystemNavigation class >> #default` returns a CompiledMethod with
  // non-empty source — confirms the metaclass path through `>>` is wired
  // (the resolver routes `class = 'Metaclass'` receivers to the
  // `{class_method, _}` handler, which now plumbs `class_method_source`
  // into `__source__`).
  testMetaclassMethodHasSource =>
    cm := SystemNavigation class >> #default
    self deny: cm isNil
    self deny: cm source isEmpty

  // Composition primitives must work on a metaclass scope.
  // `SystemNavigation class methods` returns class-side selectors (via
  // `classLocalMethods`'s `'Metaclass'` clause), and the metaclass
  // receiver responds to `>>` (so the `respondsTo:` guard in
  // `collectSendersFor:in:into:` does not skip class-side scopes).
  testMetaclassScopePrimitivesPresent =>
    self assert: ((SystemNavigation class) methods includes: #default)
    self assert: ((SystemNavigation class) respondsTo: #'>>')

  // --- BT-2196: extension method scanning ---

  // The extension-scan helper is present (the `sendersOf:` body delegates
  // to it after the class-side walk). Behavioural coverage — that
  // register/5-source extensions actually surface in `sendersOf:` results —
  // lives in the E2E REPL-protocol suite (`workspace_native_api.btscript`)
  // because the compiler port needed to parse extension source bodies is
  // not running under BUnit.
  testHelperCollectExtensionSendersIsDefined =>
    self assert: (SystemNavigation includesSelector: #collectExtensionSendersFor:into:)

  // The class-tag resolver helper is present.
  testHelperResolveExtensionClassIsDefined =>
    self assert: (SystemNavigation includesSelector: #resolveExtensionClass:)
