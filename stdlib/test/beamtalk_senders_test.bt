// BT-2190: BUnit-level coverage for Beamtalk `sendersOf:` — finds all call
// sites of a given selector across the loaded class registry. Backs System
// Browser-style navigation ("who calls this method?").
//
// Like `beamtalk_implementors_test.bt`, this suite is limited to class-level
// selector existence checks because the workspace singleton `Beamtalk` is
// not bootstrapped in the BUnit test context, and `BeamtalkInterface` is a
// `sealed typed Object subclass:` that cannot be instantiated.
//
// Behavioural tests for `sendersOf:` (happy path, multiple call sites in
// one method, no-senders, stdlib senders, Symbol type check) live in the
// E2E REPL-protocol suite at tests/repl-protocol/cases/workspace_native_api.btscript,
// which runs in workspace_mode and has the live `Beamtalk` singleton
// available.

TestCase subclass: BeamtalkSendersTest

  // --- selector existence ---
  testIncludesSelectorSendersOf =>
    self assert: (BeamtalkInterface includesSelector: #sendersOf:)

  // --- composition primitives must be in place ---

  // The implementation calls self allClasses, then for each class walks
  // `aClass methods` + `aClass class methods`, fetches each method via
  // `>>`, reads its `source`, and asks the compiler to find matching
  // MessageSend lines. All of those primitives have to be present.
  testCompositionPrimitivesPresent =>
    self assert: (BeamtalkInterface includesSelector: #allClasses)
    self assert: (Behaviour includesSelector: #methods)
    self assert: (Behaviour includesSelector: #'>>')
    self assert: (CompiledMethod includesSelector: #source)

  // The internal helper `collectSendersFor:in:into:` factors out per-class
  // iteration so both instance and class-side method dictionaries are walked.
  testHelperCollectSendersIsDefined =>
    self assert: (BeamtalkInterface includesSelector: #collectSendersFor:in:into:)
