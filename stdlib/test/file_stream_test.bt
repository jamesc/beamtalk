// File streaming tests (BT-513)

TestCase subclass: FileStreamTest

  testFileLinesBasicReading =>
    self assert: (File lines: "test/fixtures/stream_test.txt") isOk
    self
      assert: (File open: "test/fixtures/stream_test.txt" do: [:h |
        h lines asList size
      ]) unwrap
      equals: 3
    self assert: (File lines: "test/fixtures/stream_single.txt") isOk
    self assert: (File lines: "test/fixtures/stream_no_trailing.txt") isOk

  testEmptyFile =>
    // Empty file returns empty stream
    self assert: (File lines: "test/fixtures/stream_empty.txt") isOk
    self assert: (File open: "test/fixtures/stream_empty.txt" do: [:h |
      h lines asList
    ]) unwrap equals: #()

  testStreamPipelineComposition =>
    // Pipeline operations are verified through open:do: (see testFileOpenDoBlockScopedHandle)
    self assert: (File lines: "test/fixtures/stream_test.txt") isOk

  testFileOpenDoBlockScopedHandle =>
    // Read lines through handle
    self
      assert: (File open: "test/fixtures/stream_test.txt" do: [:handle |
        handle lines asList
      ]) unwrap
      equals: #("line one", "line two", "line three")
    // Take lines through handle
    self
      assert: (File open: "test/fixtures/stream_test.txt" do: [:handle |
        handle lines take: 1
      ]) unwrap
      equals: #("line one")
    // Pipeline through handle
    self
      assert: (File open: "test/fixtures/stream_test.txt" do: [:handle |
        (handle lines select: [:l | l includesSubstring: "two"]) asList
      ]) unwrap
      equals: #("line two")
    // Block returns result
    self
      assert: (File open: "test/fixtures/stream_test.txt" do: [:handle |
        handle lines inject: 0 into: [:count :line | count + 1]
      ]) unwrap
      equals: 3
    // Empty file through handle
    self
      assert: (File open: "test/fixtures/stream_empty.txt" do: [:handle |
        handle lines asList
      ]) unwrap
      equals: #()

  testLazyEvaluationConstantMemory =>
    // Lazy take: reads only N lines from a large file; count with inject:into:
    self
      assert: (File open: "test/fixtures/stream_large.txt" do: [:h |
        (h lines take: 3) inject: 0 into: [:count :_ | count + 1]
      ]) unwrap
      equals: 3

  testDoSideEffects =>
    // do: iterates all lines; verify count via inject:into:
    self
      assert: (File open: "test/fixtures/stream_test.txt" do: [:h |
        h lines inject: 0 into: [:count :line | count + 1]
      ]) unwrap
      equals: 3

  testPrintstringStreamDescription =>
    // Stream printString returns a non-empty description
    stream := (File lines: "test/fixtures/stream_test.txt") unwrap
    self assert: ((stream printString size) > 0)

  testStreamFinalizerPartialConsumption =>
    // Partial consumption via open:do: returns only the taken lines
    self assert: (File open: "test/fixtures/stream_test.txt" do: [:h |
      h lines take: 1
    ]) unwrap equals: #("line one")
    self assert: (File lines: "test/fixtures/stream_large.txt") isOk

  testErrorPaths =>
    // File not found returns file_not_found error
    notFound := File lines: "test/fixtures/nonexistent.txt"
    self assert: notFound isError
    self assert: (notFound error printString includesSubstring: "file not found")
    // Type error: non-string path
    @expect type
    self should: [File lines: 42] raise: #type_error
    // File not found with open:do:
    self assert: (File open: "test/fixtures/nonexistent.txt" do: [:h |
      h lines asList
    ]) isError

  testErrorPathsTypeErrors =>
    // Type errors that produce compile-time warnings but still run correctly
    @expect type
    self should: [File open: 42 do: [:h | h lines asList]] raise: #type_error
    @expect type
    self should: [
      File open: "test/fixtures/stream_test.txt" do: "not a block"
    ] raise: #type_error

  testWindowsStyleLineEndingsRN =>
    // Windows CRLF line endings are stripped correctly
    self assert: (File lines: "test/fixtures/stream_crlf.txt") isOk

  testUnicodeFileContent =>
    // Unicode content (multi-byte UTF-8) reads correctly through streams
    self assert: (File lines: "test/fixtures/stream_unicode.txt") isOk

  testOpenDoConcreteReturnValueCheck =>
    // BT-1273: File open:do: returns Result; unwrap gives the block value.
    // BT-1576: With generic Result(T, E), unwrap returns Dynamic for
    // unparameterized Results — no DNU hint, no @expect type needed.
    result := (File open: "test/fixtures/stream_test.txt" do: [:handle |
      handle lines asList
    ]) unwrap
    self assert: result size equals: 3
