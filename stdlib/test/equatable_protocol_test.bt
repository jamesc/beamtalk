// BT-2867 follow-up: Equatable protocol conformance tests.
// Verifies that the Equatable protocol is registered and that classes
// with `=:=` conform structurally (ADR 0068).

TestCase subclass: EquatableProtocolTest

  // --- Protocol registration ---
  testEquatableIsRegistered => self assert: (Protocol isProtocol: #Equatable)

  testRequiredMethods =>
    methods := Protocol requiredMethods: #Equatable
    self assert: methods size equals: 1
    self assert: (methods includes: #'=:=')

  testAllProtocolsIncludesEquatable =>
    self assert: (Protocol allProtocols includes: #Equatable)

  // --- Conforming classes (have `=:=`) ---
  testIntegerConforms => self assert: (Integer conformsTo: #Equatable)

  testFloatConforms => self assert: (Float conformsTo: #Equatable)

  testStringConforms => self assert: (String conformsTo: #Equatable)

  testCharacterConforms => self assert: (Character conformsTo: #Equatable)

  testSymbolConforms => self assert: (Symbol conformsTo: #Equatable)

  testDateTimeConforms => self assert: (DateTime conformsTo: #Equatable)

  testPidConforms => self assert: (Pid conformsTo: #Equatable)

  testPortConforms => self assert: (Port conformsTo: #Equatable)

  testReferenceConforms => self assert: (Reference conformsTo: #Equatable)

  // --- Non-conforming class (no =:= in hierarchy) ---
  testDictionaryDoesNotConform => self deny: (Dictionary conformsTo: #Equatable)

  testTupleDoesNotConform =>
    // Tuple has `at:`/`isOk`/etc. but no `=:=` of its own.
    self deny: (Tuple conformsTo: #Equatable)

  // --- Actual usage: assert:equals: now types both args as Equatable ---
  testAssertEqualsAcceptsEquatableValues =>
    self assert: 1 equals: 1
    self assert: "abc" equals: "abc"
    self assert: #sym equals: #sym
