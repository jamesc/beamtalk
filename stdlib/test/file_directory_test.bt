// File directory operation tests (BT-1120)

TestCase subclass: FileDirectoryTest

  // Clean up the test scratch area before each test for isolation.
  // Must return self so the BUnit runner uses this instance as the test receiver.
  setUp =>
    (File isDirectory: "target/bt-test-tmp/fdt") ifTrue: [
      (File deleteAll: "target/bt-test-tmp/fdt") unwrap
    ]
    (File mkdirAll: "target/bt-test-tmp/fdt") unwrap
    self

  // Remove the scratch area after the suite finishes.
  tearDown =>
    (File isDirectory: "target/bt-test-tmp/fdt") ifTrue: [
      (File deleteAll: "target/bt-test-tmp/fdt") unwrap
    ]

  testIsDirectoryOnExistingDirectory =>
    self assert: (File isDirectory: "target/bt-test-tmp/fdt")

  testIsDirectoryOnFile =>
    self assert: (File writeAll: "target/bt-test-tmp/fdt/isdir_file.txt" contents: "hello") isOk
    self deny: (File isDirectory: "target/bt-test-tmp/fdt/isdir_file.txt")

  testIsDirectoryOnMissingPath =>
    self deny: (File isDirectory: "target/bt-test-tmp/fdt/no_such_dir")

  testIsDirectoryInvalidPath => self deny: (File isDirectory: "../parent")

  testIsFileOnFile =>
    self assert: (File writeAll: "target/bt-test-tmp/fdt/isfile_check.txt" contents: "data") isOk
    self assert: (File isFile: "target/bt-test-tmp/fdt/isfile_check.txt")

  testIsFileOnDirectory => self deny: (File isFile: "target/bt-test-tmp/fdt")

  testIsFileOnMissingPath =>
    self deny: (File isFile: "target/bt-test-tmp/fdt/no_such_file.txt")

  testIsFileInvalidPath => self deny: (File isFile: "../secret.txt")

  testMkdir =>
    self assert: (File mkdir: "target/bt-test-tmp/fdt/mkdir_test") isOk
    self assert: (File isDirectory: "target/bt-test-tmp/fdt/mkdir_test")

  testMkdirAlreadyExistsRaisesError =>
    self assert: (File mkdir: "target/bt-test-tmp/fdt/mkdir_exists") isOk
    self assert: (File mkdir: "target/bt-test-tmp/fdt/mkdir_exists") isError

  testMkdirMissingParentRaisesError =>
    self assert: (File mkdir: "target/bt-test-tmp/fdt/no_parent/child") isError

  testMkdirInvalidPathRaisesError =>
    self assert: (File mkdir: "/tmp/evil") isError
    self assert: (File mkdir: "../escape") isError

  testMkdirTypeErrorRaisesError =>
    @expect type
    self should: [File mkdir: 42] raise: #type_error

  testMkdirAll =>
    self assert: (File mkdirAll: "target/bt-test-tmp/fdt/a/b/c") isOk
    self assert: (File isDirectory: "target/bt-test-tmp/fdt/a/b/c")

  testMkdirAllIdempotent =>
    self assert: (File mkdirAll: "target/bt-test-tmp/fdt/idem") isOk
    self assert: (File mkdirAll: "target/bt-test-tmp/fdt/idem") isOk
    self assert: (File isDirectory: "target/bt-test-tmp/fdt/idem")

  testMkdirAllInvalidPathRaisesError =>
    self assert: (File mkdirAll: "/tmp/evil") isError
    self assert: (File mkdirAll: "../escape") isError

  testMkdirAllTypeErrorRaisesError =>
    @expect type
    self should: [File mkdirAll: 42] raise: #type_error

  testListDirectory =>
    self assert: (File writeAll: "target/bt-test-tmp/fdt/a.txt" contents: "a") isOk
    self assert: (File writeAll: "target/bt-test-tmp/fdt/b.txt" contents: "b") isOk
    entries := (File listDirectory: "target/bt-test-tmp/fdt") unwrap
    self assert: (entries printString includesSubstring: "a.txt")
    self assert: (entries printString includesSubstring: "b.txt")

  testListDirectoryContainsExpectedEntry =>
    self assert: (File writeAll: "target/bt-test-tmp/fdt/hello.txt" contents: "hi") isOk
    self assert: (File listDirectory: "target/bt-test-tmp/fdt") isOk
    self assert: (File isFile: "target/bt-test-tmp/fdt/hello.txt")

  testListDirectoryEmptyDirectory =>
    self assert: (File mkdirAll: "target/bt-test-tmp/fdt/empty") isOk
    self assert: (File listDirectory: "target/bt-test-tmp/fdt/empty") isOk

  testListDirectoryMissingRaisesError =>
    self assert: (File listDirectory: "target/bt-test-tmp/fdt/no_such_dir") isError

  testListDirectoryOnFileRaisesError =>
    self assert: (File writeAll: "target/bt-test-tmp/fdt/not_a_dir.txt" contents: "x") isOk
    self assert: (File listDirectory: "target/bt-test-tmp/fdt/not_a_dir.txt") isError

  testListDirectoryInvalidPathRaisesError =>
    self assert: (File listDirectory: "/etc") isError
    self assert: (File listDirectory: "../parent") isError

  testListDirectoryTypeErrorRaisesError =>
    @expect type
    self should: [File listDirectory: 42] raise: #type_error

  testDeleteFile =>
    self assert: (File writeAll: "target/bt-test-tmp/fdt/delete_me.txt" contents: "bye") isOk
    self assert: (File delete: "target/bt-test-tmp/fdt/delete_me.txt") isOk
    self deny: (File exists: "target/bt-test-tmp/fdt/delete_me.txt")

  testDeleteEmptyDirectory =>
    self assert: (File mkdir: "target/bt-test-tmp/fdt/delete_dir") isOk
    self assert: (File delete: "target/bt-test-tmp/fdt/delete_dir") isOk
    self deny: (File isDirectory: "target/bt-test-tmp/fdt/delete_dir")

  testDeleteNonExistentRaisesError =>
    self assert: (File delete: "target/bt-test-tmp/fdt/no_such_file.txt") isError

  testDeleteNonEmptyDirectoryRaisesError =>
    self assert: (File mkdirAll: "target/bt-test-tmp/fdt/nonempty") isOk
    self assert: (File writeAll: "target/bt-test-tmp/fdt/nonempty/child.txt" contents: "x") isOk
    self assert: (File delete: "target/bt-test-tmp/fdt/nonempty") isError

  testDeleteInvalidPathRaisesError =>
    self assert: (File delete: "/tmp/evil.txt") isError
    self assert: (File delete: "../escape.txt") isError

  testDeleteTypeErrorRaisesError =>
    @expect type
    self should: [File delete: 42] raise: #type_error

  testDeleteAll =>
    self assert: (File mkdirAll: "target/bt-test-tmp/fdt/tree/a/b") isOk
    self assert: (File writeAll: "target/bt-test-tmp/fdt/tree/a/b/file.txt" contents: "x") isOk
    self assert: (File deleteAll: "target/bt-test-tmp/fdt/tree") isOk
    self deny: (File isDirectory: "target/bt-test-tmp/fdt/tree")

  testDeleteAllNonExistentRaisesError =>
    self assert: (File deleteAll: "target/bt-test-tmp/fdt/no_such_dir") isError

  testDeleteAllInvalidPathRaisesError =>
    self assert: (File deleteAll: "/tmp/evil") isError
    self assert: (File deleteAll: "../escape") isError

  testDeleteAllTypeErrorRaisesError =>
    @expect type
    self should: [File deleteAll: 42] raise: #type_error

  testRename =>
    self assert: (File writeAll: "target/bt-test-tmp/fdt/src.txt" contents: "content") isOk
    self assert: (File rename: "target/bt-test-tmp/fdt/src.txt" to: "target/bt-test-tmp/fdt/dst.txt") isOk
    self deny: (File exists: "target/bt-test-tmp/fdt/src.txt")
    self assert: (File exists: "target/bt-test-tmp/fdt/dst.txt")
    self assert: (File readAll: "target/bt-test-tmp/fdt/dst.txt") unwrap equals: "content"

  testRenameDirectory =>
    self assert: (File mkdir: "target/bt-test-tmp/fdt/dir_src") isOk
    self assert: (File rename: "target/bt-test-tmp/fdt/dir_src" to: "target/bt-test-tmp/fdt/dir_dst") isOk
    self deny: (File isDirectory: "target/bt-test-tmp/fdt/dir_src")
    self assert: (File isDirectory: "target/bt-test-tmp/fdt/dir_dst")

  testRenameNonExistentRaisesError =>
    self assert: (File rename: "target/bt-test-tmp/fdt/no_such_file.txt" to: "target/bt-test-tmp/fdt/dst.txt") isError

  testRenameInvalidSourcePathRaisesError =>
    self assert: (File rename: "/tmp/evil.txt" to: "target/bt-test-tmp/fdt/dst.txt") isError

  testRenameInvalidDestPathRaisesError =>
    self assert: (File writeAll: "target/bt-test-tmp/fdt/rename_src.txt" contents: "x") isOk
    self assert: (File rename: "target/bt-test-tmp/fdt/rename_src.txt" to: "/tmp/evil.txt") isError

  testRenameTypeErrorRaisesError =>
    @expect type
    self should: [
      File rename: 42 to: "target/bt-test-tmp/fdt/dst.txt"
    ] raise: #type_error

  testAbsolutePath =>
    result := File absolutePath: "target/bt-test-tmp/fdt"
    self assert: result isOk
    self assert: (result unwrap printString includesSubstring: "bt-test-tmp/fdt")

  testAbsolutePathIsAbsolute =>
    result := File absolutePath: "target/bt-test-tmp/fdt"
    self assert: result isOk
    System osFamily == "unix" ifTrue: [
      self assert: (result unwrap printString includesSubstring: "/")
    ]

  testAbsolutePathInvalidRaisesError =>
    self assert: (File absolutePath: "/etc/passwd") isError
    self assert: (File absolutePath: "../secret") isError

  testAbsolutePathTypeErrorRaisesError =>
    @expect type
    self should: [File absolutePath: 42] raise: #type_error

  testCwd =>
    cwd := File cwd
    self assert: (cwd size > 0)

  testCwdIsString =>
    cwd := File cwd
    self assert: (cwd class name) equals: #String

  testCwdIsAbsolute =>
    // Unix only: absolute paths always start with '/'
    System osFamily == "unix" ifFalse: [^self skip: "Unix only"]
    cwd := File cwd
    self assert: (cwd includesSubstring: "/")

  testTempDirectory =>
    tmp := File tempDirectory
    self assert: (tmp size > 0)

  testTempDirectoryIsString =>
    tmp := File tempDirectory
    self assert: (tmp class name) equals: #String
