// BT-1325 Layer 2: Tests that mutual actor calls (A calls B, B calls back A)
// are detected immediately via call-stack cycle detection in PropCtx,
// raising a #deadlock_detected error instead of waiting for a 5s timeout.

TestCase subclass: ActorDeadlockTest

  // Two actors calling each other synchronously creates a deadlock
  // BT-1325: Now detected immediately via call_stack in PropCtx
  testMutualCallDeadlockRaisesDeadlockDetected =>
    a := DeadlockA spawn
    b := DeadlockB spawn
    a setPeer: b
    self should: [a callPeer] raise: #deadlock_detected

  // Three actors in a cycle: A -> B -> C -> A
  // BT-1325: Detected immediately via call_stack threading in PropCtx
  testThreeActorCycleRaisesDeadlockDetected =>
    a := CycleActorA spawn
    b := CycleActorB spawn
    c := CycleActorC spawn
    a setPeer: b
    b setPeer: c
    self should: [a startCycle] raise: #deadlock_detected
