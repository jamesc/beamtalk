// Tests the Package class — all, named:, classes:, dependencies:, packageNameFor:
// and Metaclass packageName/package methods (ADR 0070 Phase 5)

TestCase subclass: PackageTest

  testAll =>
    // Package all returns a collection of package name strings
    pkgs := Package all
    // The stdlib package is always present
    self assert: (pkgs includes: "stdlib")

  testNamedStdlib =>
    // Package named: returns a Package object
    pkg := Package named: "stdlib"
    self assert: (pkg class =:= Package)
    // Has accessors
    self assert: pkg name equals: "stdlib"
    // version is a non-empty string
    self assert: (pkg version class =:= String)
    self assert: (pkg version size > 0)
    // classes includes core classes
    self assert: (pkg classes includes: #Object)

  testNamedNotFound =>
    // Package named: with unknown name raises a package_not_found error
    self should: [
      Package named: "nonexistent_package_xyz_99"
    ] raise: #package_not_found

  testClassesStdlib =>
    // Package classes: returns the class names in the package
    classes := Package classes: "stdlib"
    self assert: (classes includes: #Object)
    self assert: (classes includes: #Integer)
    self assert: (classes includes: #String)

  testClassesUnknown =>
    // Package classes: with unknown package returns empty collection
    classes := Package classes: "nonexistent_package_xyz_99"
    self assert: (classes isEmpty)

  testDependenciesStdlib =>
    // Package dependencies: returns dependency package names as a collection
    deps := Package dependencies: "stdlib"
    self deny: deps isNil

  testPackageNameFor =>
    // Package packageNameFor: returns the package name for a known class
    name := Package packageNameFor: #Object
    self assert: name equals: "stdlib"

  testPackageNameForUnknown =>
    // Package packageNameFor: returns nil for an unknown class
    name := Package packageNameFor: #NonexistentClassXYZ99
    self assert: name equals: nil

  testMetaclassPackageName =>
    // Metaclass packageName returns the package name string
    name := Integer class packageName
    self assert: name equals: "stdlib"

  testMetaclassPackage =>
    // Metaclass package returns a Package object
    pkg := Integer class package
    self assert: (pkg class =:= Package)
    self assert: pkg name equals: "stdlib"
