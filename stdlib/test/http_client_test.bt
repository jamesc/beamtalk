// BT-1116: Tests for HTTPClient actor class — lifecycle, state initialisation,
// and class identity. Integration tests (actual HTTP requests) are in BT-1117.

TestCase subclass: HTTPClientTest

  testSpawnAndStop =>
    // HTTPClient is an Actor subclass — spawn/stop lifecycle works
    client := HTTPClient spawn
    self assert: client isAlive
    self assert: client stop equals: #ok
    self deny: client isAlive

  testSpawnWithBaseUrl =>
    // spawnWith: sets baseUrl state; actor is alive after spawn
    client := HTTPClient spawnWith: #{#baseUrl => "https://httpbin.org"}
    self assert: client isAlive
    self assert: client stop equals: #ok

  testSpawnWithAllOptions =>
    // All three state fields are accepted by spawnWith:
    client := HTTPClient spawnWith: #{
      #baseUrl => "https://httpbin.org",
      #headers => #(#("X-Custom", "value")),
      #timeout => 10000
    }
    self assert: client isAlive
    self assert: client stop equals: #ok

  testSpawnWithInvalidArgumentRaisesTypeError =>
    // Non-Dictionary argument to spawnWith: raises type_error
    self should: [HTTPClient spawnWith: 42] raise: #type_error
    self should: [HTTPClient spawnWith: "bad"] raise: #type_error

  testNewRaisesInstantiationError =>
    // HTTPClient.new raises instantiation_error (must use spawn/spawnWith:).
    // @expect all: intentionally calling new on an Actor to verify it raises the error.
    @expect all
    self should: [HTTPClient new] raise: #instantiation_error

  testPrintStringInstance =>
    // Actor instance printString returns "a HTTPClient"
    client := HTTPClient spawn
    self assert: client printString equals: "a HTTPClient"
    self assert: client stop equals: #ok

  testClassIdentity =>
    // HTTPClient class is an Actor subclass
    self assert: HTTPClient superclass equals: Actor
