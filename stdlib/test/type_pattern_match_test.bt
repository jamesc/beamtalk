// BT-2855 / ADR 0107 Phase A: runtime tests for `nil` and `binding ::
// ClassName` patterns in `match:` — bindings, narrowing, and codegen for
// every Phase A primitive (String, Integer, Float, List, Dictionary,
// Boolean, Symbol) plus an exact tagged `Value` class, a `when:` guard
// scoped over the type-pattern binding, and a `match:` mixing pattern
// kinds in one dispatch.
//
// Fixtures: stdlib/test/fixtures/value_point.bt (ValuePoint — a leaf
// `Value subclass:` with no subclasses, used for the tagged-class arm)
//           stdlib/test/fixtures/type_pattern_actor_fixture.bt
//           (TypePatternActorFixture — a leaf `Actor subclass:` with no
//           subclasses anywhere in the test corpus, used for the
//           actor-reference arm; an actor reference is a 4-tuple at
//           runtime, not a map, so it needs its own codegen strategy
//           distinct from `ValuePoint`'s map-tag check)
//           stdlib/test/fixtures/type_pattern_supervisor_fixture.bt,
//           stdlib/test/fixtures/type_pattern_dynamic_supervisor_fixture.bt
//           (BT-2870: leaf `Supervisor`/`DynamicSupervisor` subclasses with
//           no other subclasses in the test corpus, used for the
//           supervisor-reference arm; a supervisor reference is also a
//           4-tuple at runtime, but tagged `'beamtalk_supervisor'` rather
//           than `'beamtalk_object'`, so it needs its own codegen strategy
//           distinct from the actor arm above)

TestCase subclass: TypePatternMatchTest

  testNilPattern =>
    self
      assert: (nil match: [
        nil -> 0;
        s :: String -> s size;
        _ -> -1
      ])
      equals: 0

  testStringPattern =>
    self
      assert: ("hi" match: [
        nil -> 0;
        s :: String -> s size;
        _ -> -1
      ])
      equals: 2

  testFallthroughToWildcard =>
    self
      assert: (42 match: [
        nil -> 0;
        s :: String -> s size;
        _ -> -1
      ])
      equals: -1

  testIntegerPattern =>
    self
      assert: (7 match: [
        n :: Integer -> n + 1;
        _ -> -1
      ])
      equals: 8

  testFloatPattern =>
    self
      assert: (1.5 match: [
        f :: Float -> f + 0.5;
        _ -> -1
      ])
      equals: 2.0

  testListPattern =>
    self
      assert: (#(1, 2, 3) match: [
        l :: List -> l size;
        _ -> -1
      ])
      equals: 3

  testDictionaryPattern =>
    self
      assert: (#{#a => 1} match: [
        d :: Dictionary -> d size;
        _ -> -1
      ])
      equals: 1

  testBooleanPatternTrue =>
    self
      assert: (true match: [
        b :: Boolean -> b;
        _ -> #other
      ])
      equals: true

  testBooleanPatternFalse =>
    self
      assert: (false match: [
        b :: Boolean -> b;
        _ -> #other
      ])
      equals: false

  // `Symbol`/`nil`/`Boolean` are all plain Erlang atoms with no
  // distinguishing runtime tag — an earlier `s :: Symbol` arm must not
  // shadow a later `nil ->` or `b :: Boolean` arm (ADR 0107 Phase A).
  testSymbolPatternDoesNotMatchNil =>
    self
      assert: (nil match: [
        s :: Symbol -> #matched;
        nil -> #isNil;
        _ -> #other
      ])
      equals: #isNil

  testSymbolPatternDoesNotMatchBoolean =>
    self
      assert: (true match: [
        s :: Symbol -> #matched;
        b :: Boolean -> #isBoolean;
        _ -> #other
      ])
      equals: #isBoolean

  testSymbolPatternMatchesPlainSymbol =>
    self
      assert: (#ok match: [
        s :: Symbol -> s;
        _ -> #other
      ])
      equals: #ok

  // Exact tagged `Value`/sealed classes use the map-tag (`$beamtalk_class`)
  // check, generalized from the constructor pattern's hardcoded `Result`.
  testTaggedValueClassPattern =>
    p := ValuePoint new: #{#x => 3, #y => 4}
    self
      assert: (p match: [
        pt :: ValuePoint -> pt distanceSquared;
        _ -> -1
      ])
      equals: 25

  // The binding's scope includes the arm's `when:` guard, not just its
  // body (ADR 0107 Phase A) — the guard below references `n`, which only
  // exists because the `Type` pattern's binding is already in scope by the
  // time the guard is evaluated.
  testGuardScopedOverTypeBinding =>
    self
      assert: (10 match: [
        n :: Integer when: [n > 5] -> "big";
        n :: Integer -> "small";
        _ -> "other"
      ])
      equals: "big"
    self
      assert: (2 match: [
        n :: Integer when: [n > 5] -> "big";
        n :: Integer -> "small";
        _ -> "other"
      ])
      equals: "small"

  // A `match:` mixing a primitive `Type` arm and a tagged-class `Type` arm
  // must dispatch correctly for both, plus fall through to a wildcard.
  testMixedPrimitiveAndTaggedClassArmsInOneMatch =>
    p := ValuePoint new: #{#x => 1, #y => 1}
    self
      assert: ("hi" match: [
        s :: String -> #string;
        pt :: ValuePoint -> #point;
        _ -> #other
      ])
      equals: #string
    self
      assert: (p match: [
        s :: String -> #string;
        pt :: ValuePoint -> #point;
        _ -> #other
      ])
      equals: #point
    self
      assert: (42 match: [
        s :: String -> #string;
        pt :: ValuePoint -> #point;
        _ -> #other
      ])
      equals: #other

  // A Beamtalk block compiles to a plain Erlang `fun`, never a map.
  testBlockPattern =>
    self
      assert: ([:x | x + 1] match: [
        blk :: Block -> (blk value: 41);
        _ -> -1
      ])
      equals: 42

  // `True`/`False` are real sealed `Boolean` subclasses, and
  // `Nil`/`UndefinedObject` are the nil class (canonical + legacy alias,
  // BT-2016) — all four compile to a bare atom, never a map.
  testTrueFalseNilUndefinedObjectPatterns =>
    self
      assert: (true match: [
        t :: True -> #wasTrue;
        f :: False -> #wasFalse;
        _ -> #other
      ])
      equals: #wasTrue
    self
      assert: (false match: [
        t :: True -> #wasTrue;
        f :: False -> #wasFalse;
        _ -> #other
      ])
      equals: #wasFalse
    self
      assert: (nil match: [
        n :: Nil -> #wasNil;
        _ -> #other
      ])
      equals: #wasNil
    self
      assert: (nil match: [
        u :: UndefinedObject -> #wasNil;
        _ -> #other
      ])
      equals: #wasNil

  // BT-2855 regression: an actor reference is `{'beamtalk_object',
  // ClassAtom, ModuleAtom, Pid}` at runtime — a 4-tuple, not a map. Naively
  // reusing the tagged-class `is_map` check for Actor subclasses would
  // silently never match a live actor instance.
  testActorClassPattern =>
    a := TypePatternActorFixture spawn
    self
      assert: (a match: [
        actor :: TypePatternActorFixture -> #wasActor;
        _ -> #other
      ])
      equals: #wasActor
    self
      assert: (42 match: [
        actor :: TypePatternActorFixture -> #wasActor;
        _ -> #other
      ])
      equals: #other

  // BT-2870 regression: a Supervisor subclass reference is a THIRD runtime
  // shape — also a 4-tuple, but tagged 'beamtalk_supervisor' rather than
  // 'beamtalk_object'. Naively reusing either the tagged-map or
  // actor-tuple strategy would silently never match a live supervisor
  // reference.
  testSupervisorClassPattern =>
    sup := (TypePatternSupervisorFixture supervise) unwrap
    self
      assert: (sup match: [
        s :: TypePatternSupervisorFixture -> #wasSupervisor;
        _ -> #other
      ])
      equals: #wasSupervisor
    self
      assert: (42 match: [
        s :: TypePatternSupervisorFixture -> #wasSupervisor;
        _ -> #other
      ])
      equals: #other
    [sup stop] on: Error do: [:e | nil]

  // BT-2870: DynamicSupervisor subclasses use the same
  // 'beamtalk_supervisor' tuple shape as Supervisor subclasses.
  testDynamicSupervisorClassPattern =>
    pool := (TypePatternDynamicSupervisorFixture supervise) unwrap
    self
      assert: (pool match: [
        p :: TypePatternDynamicSupervisorFixture -> #wasPool;
        _ -> #other
      ])
      equals: #wasPool
    self
      assert: (42 match: [
        p :: TypePatternDynamicSupervisorFixture -> #wasPool;
        _ -> #other
      ])
      equals: #other
    [pool stop] on: Error do: [:e | nil]

  // BT-2870: `element(2)` must discriminate between two supervisor-tagged
  // classes — a Supervisor instance must not match a DynamicSupervisor
  // pattern, even though both compile to the same
  // `{'beamtalk_supervisor', ClassAtom, ModuleAtom, Pid}` shape.
  testSupervisorClassPatternDiscriminatesSiblingClasses =>
    sup := (TypePatternSupervisorFixture supervise) unwrap
    self
      assert: (sup match: [
        p :: TypePatternDynamicSupervisorFixture -> #wrongMatch;
        s :: TypePatternSupervisorFixture -> #wasSupervisor;
        _ -> #other
      ])
      equals: #wasSupervisor
    [sup stop] on: Error do: [:e | nil]

  // BT-2870: an actor reference must not match a supervisor type pattern
  // (or vice versa) — both are 4-tuples, but with different `element(1)`
  // tags ('beamtalk_object' vs 'beamtalk_supervisor').
  testSupervisorAndActorPatternsDoNotCrossMatch =>
    actor := TypePatternActorFixture spawn
    self
      assert: (actor match: [
        s :: TypePatternSupervisorFixture -> #wrongMatch;
        a :: TypePatternActorFixture -> #wasActor;
        _ -> #other
      ])
      equals: #wasActor
    sup := (TypePatternSupervisorFixture supervise) unwrap
    self
      assert: (sup match: [
        a :: TypePatternActorFixture -> #wrongMatch;
        s :: TypePatternSupervisorFixture -> #wasSupervisor;
        _ -> #other
      ])
      equals: #wasSupervisor
    [sup stop] on: Error do: [:e | nil]

  // BT-2870: a live supervisor reference is also a plain Erlang tuple
  // structurally, but must not match `x :: Tuple` — `wrap_tuple_test`
  // excludes the reserved 'beamtalk_supervisor'/'beamtalk_supervisor_new'
  // tags. Runtime counterpart to the codegen string-contains assertion in
  // control_flow.rs's
  // test_match_type_pattern_tuple_excludes_actor_reference_shape.
  testSupervisorReferenceDoesNotMatchTuplePattern =>
    sup := (TypePatternSupervisorFixture supervise) unwrap
    self
      assert: (sup match: [
        t :: Tuple -> #wasTuple;
        s :: TypePatternSupervisorFixture -> #wasSupervisor;
        _ -> #other
      ])
      equals: #wasSupervisor
    [sup stop] on: Error do: [:e | nil]
