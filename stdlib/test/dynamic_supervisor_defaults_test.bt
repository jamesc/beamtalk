// BT-1222: Tests for DynamicSupervisor class-side defaults and subclass override.
//
// Fixtures: stdlib/test/fixtures/test_dynamic_supervisor_custom.bt

TestCase subclass: DynamicSupervisorDefaultsTest

  // === DynamicSupervisor class-side defaults ===
  testDynamicSupervisorMaxRestartsDefault =>
    self assert: DynamicSupervisor maxRestarts equals: 10

  testDynamicSupervisorRestartWindowDefault =>
    self assert: DynamicSupervisor restartWindow equals: 60

  testDynamicSupervisorIsSupervisorTrue =>
    self assert: DynamicSupervisor isSupervisor equals: true

  // === DynamicSupervisor subclass can override defaults ===
  testDynamicSupervisorSubclassOverridesMaxRestarts =>
    self assert: TestDynamicSupervisorCustom maxRestarts equals: 5

  testDynamicSupervisorSubclassOverridesRestartWindow =>
    self assert: TestDynamicSupervisorCustom restartWindow equals: 120

  testDynamicSupervisorSubclassIsSupervisorTrue =>
    self assert: TestDynamicSupervisorCustom isSupervisor equals: true

  // === Type parameter C narrows startChild return type ===
  testStartChildReturnsTypedChild =>
    pool := TestDynamicSupervisorCustom supervise
    child := pool startChild
    // If C=Counter resolves, child is typed as Counter and getValue compiles.
    // Without the type parameter this would fail: "Object does not understand 'getValue'"
    self assert: child getValue equals: 0
    [pool stop] on: Error do: [:e | nil]
