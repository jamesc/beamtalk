// BUnit tests for Announcements introspection (BT-2444):
// Announcer self-inspection + AnnouncementNavigation + SubscriptionNode.
//
// Each test subscribes on its own per-instance `Announcer` (isolated per
// BT-2454) and navigates it with `AnnouncementNavigation of:`, so its reads see
// only its own subscriptions. Tests still unsubscribe in-test to keep the
// process's subscriptions clean.

TestCase subclass: AnnouncementsIntrospectionTest
  field: announcer = nil

  setUp => self withAnnouncer: Announcer new

  // --- Announcer self-inspection: subscribersOf: ---
  testSubscribersOfReturnsNodes =>
    sub := self.announcer when: IntrospectionEvent do: [:e | nil]
    nodes := self.announcer subscribersOf: IntrospectionEvent
    self assert: nodes size equals: 1
    self assert: nodes first class equals: SubscriptionNode
    sub unsubscribe

  testSubscribersOfEmptyForUnsubscribedClass =>
    nodes := self.announcer subscribersOf: ParentEvent
    self assert: nodes isEmpty equals: true

  // --- SubscriptionNode fields ---
  testNodeAnnouncementClass =>
    sub := self.announcer when: IntrospectionEvent do: [:e | nil]
    node := (self.announcer subscribersOf: IntrospectionEvent) first
    self assert: node announcementClass equals: IntrospectionEvent
    sub unsubscribe

  testNodeSubscriberIsPid =>
    sub := self.announcer when: IntrospectionEvent do: [:e | nil]
    node := (self.announcer subscribersOf: IntrospectionEvent) first
    self assert: node subscriber class equals: Pid
    sub unsubscribe

  testNodeHandlerKindDoForBlock =>
    sub := self.announcer when: IntrospectionEvent do: [:e | nil]
    node := (self.announcer subscribersOf: IntrospectionEvent) first
    self assert: node handlerKind equals: #do
    self assert: node once equals: false
    sub unsubscribe

  testNodeHandlerKindDoOnce =>
    sub := self.announcer when: IntrospectionEvent doOnce: [:e | nil]
    node := (self.announcer subscribersOf: IntrospectionEvent) first
    self assert: node handlerKind equals: #doOnce
    self assert: node once equals: true
    sub unsubscribe

  testNodeHandlerKindSend =>
    handler := Announcer new
    sub := self.announcer
      when: IntrospectionEvent
      send: #class
      to: handler
    node := (self.announcer subscribersOf: IntrospectionEvent) first
    self assert: node handlerKind equals: #send
    self assert: node isSend equals: true
    sub unsubscribe

  // --- subscriptionCount ---
  testSubscriptionCountReflectsLiveSubs =>
    before := self.announcer subscriptionCount
    sub := self.announcer when: IntrospectionEvent do: [:e | nil]
    self assert: self.announcer subscriptionCount equals: before + 1
    sub unsubscribe
    self assert: self.announcer subscriptionCount equals: before

  // --- subscriptions (full snapshot) ---
  testSubscriptionsIncludesNewSub =>
    sub := self.announcer when: IntrospectionEvent do: [:e | nil]
    matching := self.announcer subscriptions select: [:n |
      n announcementClass == IntrospectionEvent
    ]
    self assert: matching size equals: 1
    sub unsubscribe

  // --- AnnouncementNavigation default ---
  testNavigationDefaultClass =>
    nav := AnnouncementNavigation default
    self assert: nav class equals: AnnouncementNavigation

  // Subscriptions are made on a per-instance announcer (BT-2454), so navigate
  // that announcer with `of:` — `default` would scope to the system bus.
  testNavigationSubscribersOf =>
    sub := self.announcer when: IntrospectionEvent do: [:e | nil]
    nodes := (AnnouncementNavigation of: self.announcer) subscribersOf: IntrospectionEvent
    self assert: nodes size equals: 1
    self assert: nodes first announcementClass equals: IntrospectionEvent
    sub unsubscribe

  testNavigationAnnouncedClassesIncludesSubscribedClass =>
    sub := self.announcer when: IntrospectionEvent do: [:e | nil]
    classes := (AnnouncementNavigation of: self.announcer) announcedClasses
    self assert: (classes includes: IntrospectionEvent) equals: true
    sub unsubscribe

  testNavigationAnnouncedClassesExcludesUnsubscribed =>
    sub := self.announcer when: IntrospectionEvent do: [:e | nil]
    classes := (AnnouncementNavigation of: self.announcer) announcedClasses
    self assert: (classes includes: ParentEvent) equals: false
    sub unsubscribe

  // --- AnnouncementNavigation of: ---
  testNavigationOfReturnsNavigation =>
    nav := AnnouncementNavigation of: self.announcer
    self assert: nav class equals: AnnouncementNavigation

  // --- SubscriptionNode printString ---
  testNodePrintStringMentionsClass =>
    sub := self.announcer when: IntrospectionEvent do: [:e | nil]
    node := (self.announcer subscribersOf: IntrospectionEvent) first
    self assert: (node printString includesSubstring: "IntrospectionEvent") equals: true
    self assert: (node printString includesSubstring: "SubscriptionNode") equals: true
    sub unsubscribe
