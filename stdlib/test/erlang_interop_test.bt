// Stdlib tests for Erlang interop (ADR 0028, BT-677, BT-682)

TestCase subclass: ErlangInteropTest

  testModuleProxyConstruction =>
    // Unary message on Erlang constructs ErlangModule proxy
    self assert: (Erlang lists) class equals: ErlangModule
    self assert: (Erlang maps) class equals: ErlangModule
    self assert: (Erlang erlang) class equals: ErlangModule

  testErlangFunctionCallsKeywordMessages =>
    // Single keyword: lists:reverse/1
    self assert: (Erlang lists reverse: #(3, 2, 1)) equals: #(1, 2, 3)
    // Multi-keyword: maps:merge/2
    self assert: (Erlang maps merge: #{
      #a => 1
    } with: #{#b => 2}) equals: #{#a => 1, #b => 2}
    // lists:seq/2
    self assert: (Erlang lists seq: 1 with: 5) equals: #(1, 2, 3, 4, 5)
    // lists:nth/2
    self assert: (Erlang lists nth: 2 with: #(10, 20, 30)) equals: 20

  testErlangFunctionCallsZeroArgUnaryOnProxy =>
    // erlang:node/0 — returns the current node name as a Symbol (Erlang atom)
    self assert: ((Erlang erlang) node) class equals: Symbol

  testCachedProxy =>
    // Store proxy in variable and reuse
    proxy := Erlang lists
    self assert: (proxy reverse: #(1, 2, 3)) equals: #(3, 2, 1)
    self assert: (proxy reverse: #(#a, #b, #c)) equals: #(#c, #b, #a)

  testClassProtocolOnErlang =>
    // BT-802 (ADR 0036): class of a class returns a real metaclass object
    // Class-protocol selectors should NOT generate proxy maps
    self assert: (Erlang class) isMeta equals: true

  testProxyObjectProtocol =>
    proxy := Erlang lists
    self assert: proxy class equals: ErlangModule
    self assert: (proxy == proxy)
    self deny: proxy isNil
    self assert: proxy notNil

  testBt682DirectCallVsProxyEquivalence =>
    // Single-arg keyword: direct vs proxy
    directResult := Erlang lists reverse: #(1, 2, 3)
    // produce identical results
    proxyLists := Erlang lists
    // Verify optimized (direct call) and unoptimized (cached proxy) paths
    proxyResult := proxyLists reverse: #(1, 2, 3)
    self assert: (directResult =:= proxyResult)
    // Multi-arg keyword: direct vs proxy
    directSeq := Erlang lists seq: 1 with: 5
    proxySeq := proxyLists seq: 1 with: 5
    self assert: (directSeq =:= proxySeq)

  // BT-2723 / ADR 0101 Part 2: wrap-by-default. A raw FFI error:* from a
  // backing module that has NO per-module try...catch wrapper (the `erlang`
  // module is raw OTP) must still surface as a structured #beamtalk_error{}
  // at the proxy boundary — never a raw `badarg` tuple. `erlang:abs/1` on a
  // non-number raises error:badarg, which the proxy wraps as a type_error.
  testRawFfiBadargSurfacesAsStructuredError =>
    kind := [(Erlang erlang) abs: #notanumber] on: TypeError do: [:e | e kind]
    self assert: kind equals: #type_error

  testRawFfiBadargIsCatchableAsExceptionWithCoherentMessage =>
    // Catchable not just as the specific TypeError but as the broad Exception
    // root, and the wrapped error is structurally identified (kind) and carries
    // a coherent String message — never a raw `badarg` tuple leaking the host VM.
    caught := [(Erlang erlang) abs: #notanumber] on: Exception do: [:e | e]
    self assert: caught kind equals: #type_error
    self assert: caught message class equals: String
