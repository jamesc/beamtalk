// BT-488, ADR 0019 Phase 1: Tests that singleton classes (BeamtalkInterface,
// TranscriptStream) expose a current accessor that returns nil before
// initialization. WorkspaceInterface.current is always set by bootstrap.

TestCase subclass: ClassVariablesSingletonTest

  testSingletonCurrentAccessors =>
    self assert: BeamtalkInterface current equals: nil
    // TranscriptStream has current accessor
    self assert: TranscriptStream current equals: nil
    // WorkspaceInterface.current is set by bootstrap; nil in BUnit context (BT-1873)
    _ := WorkspaceInterface current

  testSetAndGetCurrent =>
    // Verify that current returns the singleton (set during workspace bootstrap)
    // We can't create a new BeamtalkInterface since Object-kind classes are
    // not instantiable — just verify the accessor returns a consistent value.
    current := BeamtalkInterface current
    self assert: BeamtalkInterface current equals: current
