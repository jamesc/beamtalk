// BT-2270: The compiler auto-populates ClassBuilder `classMethodSource:` from
// `classMethods:` block-literal bodies (the class-side companion of BT-2246), so
// a class built programmatically via the ClassBuilder cascade API has its
// class-side methods visible to `SystemNavigation` source-text queries just like
// a file-defined class (BT-2195 added the class-side scanning channel).
//
// `methodsMatching:` runs in pure Beamtalk (regex over each method's source via
// `String >> #matchesRegex:`) and walks both the instance side (`cls`) and the
// class side (`cls class`, the metaclass), so it exercises the class-side source
// channel in BUnit without the compiler port that `sendersOf:` requires.
//
// The class is captured directly from `register`'s return value, which is the
// canonical, dispatchable class object (BT-2258 fixed the earlier bug where the
// programmatic-builder cascade returned an unusable wrapper).

TestCase subclass: ClassBuilderClassMethodSourceTest
  field: cls = nil

  tearDown => self.cls isNil ifFalse: [self.cls removeFromSystem]

  // Build a class with a literal-block class method, then confirm its body is
  // indexable via the class-side scan. Before BT-2270 the class method installed
  // as a bare fun with empty source and never matched a source-text query.
  testBuilderClassMethodBodyIsIndexable =>
    self.cls := Object classBuilder name: #BTBuilderClassSourceProbe;
      superclass: Object;
      classMethods: #{#shoutClass => [:_self | "hi" uppercase]};
      register
    nav := SystemNavigation default
    results := nav
      collectMethodsMatching: (Regex from: "uppercase") unwrap
      in: self.cls class
      into: List new
    self deny: results isEmpty
    selectors := results collect: [:r | r at: #selector]
    self assert: (selectors includes: #shoutClass)

  // The reconstructed source carries the keyword selector and its parameter, so
  // a query against the class-method body matches and names the selector.
  testKeywordBuilderClassMethodIsIndexable =>
    self.cls := Object classBuilder name: #BTBuilderClassKeywordProbe;
      superclass: Object;
      classMethods: #{#scaleClassBy: => [:_self :factor | factor * factor]};
      register
    nav := SystemNavigation default
    results := nav
      collectMethodsMatching: (Regex from: "factor") unwrap
      in: self.cls class
      into: List new
    selectors := results collect: [:r | r at: #selector]
    self assert: (selectors includes: #scaleClassBy:)

  // AC2: a class method built from a computed (non-literal) fun has no source
  // literal. It is still known-present (dispatchable / reflectable) but
  // unindexable — the class-side source query degrades to "no match", never a
  // crash.
  //
  // BT-2276: a computed class-method fun must follow the class-method calling
  // convention `fun(ClassSelf, ClassVars, ...)` — a unary class method is arity
  // 2 (ClassSelf, ClassVars). A wrong-arity computed fun is now rejected at
  // register time, so this conforming arity-2 block is what a real computed
  // class method looks like.
  testComputedClassMethodIsKnownButUnindexable =>
    blk := [:_self :_classVars | "x" size]
    self.cls := Object classBuilder name: #BTBuilderClassComputedProbe;
      superclass: Object;
      classMethods: #{#computedClassSize => blk};
      register
    self assert: (self.cls class includesSelector: #computedClassSize)
    nav := SystemNavigation default
    results := nav
      collectMethodsMatching: (Regex from: "size") unwrap
      in: self.cls class
      into: List new
    self assert: results isEmpty
