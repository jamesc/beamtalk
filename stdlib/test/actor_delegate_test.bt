TestCase subclass: ActorDelegateTest

  testDelegateOnNonNativeActorRaisesError =>
    counter := Counter spawn
    self should: [counter delegate] raise: #signal

  testDelegateRespondsTo =>
    counter := Counter spawn
    self assert: (counter respondsTo: #delegate)
