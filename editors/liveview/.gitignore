# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where 3rd-party dependencies like ExDoc output generated docs.
/doc/

# Ignore .fetch files in case you like to edit your project deps locally.
/.fetch

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Temporary files, for example, from tests.
/tmp/

# Ignore package tarball (built via "mix hex.build").
bt_attach-*.tar

# Assets compiled by esbuild/tailwind (run "mix assets.build"). The source
# lives in assets/; only the build output under priv/static/assets/ is ignored.
/priv/static/assets/

# esbuild/tailwind run as standalone binaries, but the JS bundle now has a real
# npm dep (CodeMirror, BT-2538) that esbuild bundles into app.js — so
# node_modules is build-only and ignored, while package-lock.json is COMMITTED
# for reproducible `npm ci`.
/assets/node_modules/

# Browser e2e (Playwright) artifacts: screenshots, traces, and saved results.
/screenshots/
/test-results/
/playwright-report/

